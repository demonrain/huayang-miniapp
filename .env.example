# Server
PORT=8787
PUBLIC_BASE_URL=http://127.0.0.1:8787
TOKEN_SECRET=replace-with-at-least-32-random-characters
NEW_USER_CREDITS=20
MAX_UPLOAD_MB=10
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# WeChat login. Keep true for local development.
WECHAT_MOCK_LOGIN=true
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_ENV_VERSION=release

# Subscribe message (job done push). Create template in MP admin, then fill ID.
# Recommended keywords: 作品风格(thing) / 生成状态(phrase) / 完成时间(time) / 温馨提示(thing)
WECHAT_SUBSCRIBE_TEMPLATE_ID=
WECHAT_SUBSCRIBE_FIELD_STYLE=thing1
WECHAT_SUBSCRIBE_FIELD_STATUS=phrase2
WECHAT_SUBSCRIBE_FIELD_TIME=time3
WECHAT_SUBSCRIBE_FIELD_TIP=thing4

# Image generation: mock | compatible
# mock = copy original upload (instant demo only)
# compatible = call OpenAI-compatible Images Edits endpoint with each template.prompt
IMAGE_PROVIDER=mock
IMAGE_API_BASE=https://api.openai.com/v1/images/edits
IMAGE_API_KEY=
IMAGE_MODEL=gpt-image-1
IMAGE_SIZE=1024x1024
# Optional: b64_json | url (leave empty for gpt-image gateways that reject response_format)
IMAGE_RESPONSE_FORMAT=
# image field name in multipart form: image | image[] (default image[])
IMAGE_FORM_IMAGE_FIELD=image[]
IMAGE_QUALITY=auto
IMAGE_OUTPUT_FORMAT=png
# Max wait per image request (ms), default 5 minutes
IMAGE_TIMEOUT_MS=300000
JOB_MOCK_DELAY_MS=800

# Payment: mock | wechat
PAYMENT_MODE=mock
WECHAT_PAY_MCH_ID=
WECHAT_PAY_CERT_SERIAL=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_NOTIFY_URL=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PLATFORM_PUBLIC_KEY_PATH=

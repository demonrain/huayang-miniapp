<view class="page history-page page-enter" style="padding-top: {{navSpacer}}rpx">
  <custom-nav credits="{{user ? user.credits : null}}"></custom-nav>

  <view class="history-heading">
    <view>
      <view class="history-kicker">MY GARDEN</view>
      <view class="section-title__main">我的作品花园</view>
      <view class="section-title__sub">每一次心动，都好好收藏</view>
    </view>
    <view class="album-count">{{total || jobs.length}} 组</view>
  </view>

  <view wx:if="{{!isLoggedIn && !loading}}" class="empty empty-work">
    <view class="empty-mark">
      <view class="empty-flower-dot"></view>
      <text>登</text>
    </view>
    <view class="empty-title">登录后查看作品</view>
    <view class="empty-sub">游客可以先逛逛模板，登录后保存你的花园</view>
    <button class="primary-button" bindtap="doLogin">微信登录</button>
  </view>

  <view wx:elif="{{loading}}" class="works-waterfall">
    <view class="works-col">
      <view class="work-card skeleton" style="height: 360rpx"></view>
      <view class="work-card skeleton" style="height: 280rpx"></view>
    </view>
    <view class="works-col">
      <view class="work-card skeleton" style="height: 300rpx"></view>
      <view class="work-card skeleton" style="height: 340rpx"></view>
    </view>
  </view>

  <block wx:elif="{{jobs.length}}">
    <!-- Two-column waterfall: left / right distributed by estimated height -->
    <view class="works-waterfall">
      <view class="works-col">
        <view
          wx:for="{{leftJobs}}"
          wx:key="id"
          class="work-card {{item.status === 'failed' ? 'work-card--failed' : ''}}"
          data-id="{{item.id}}"
          bindtap="openJob"
        >
          <view class="work-card__media" style="background: {{item.templatePalette || '#ebe6e8'}}">
            <image
              wx:if="{{item.coverUrl}}"
              class="work-card__cover"
              src="{{item.coverUrl}}"
              mode="widthFix"
              lazy-load
            ></image>
            <view wx:else class="work-card__placeholder">
              <text>{{item.templateShortName}}</text>
            </view>
            <view class="work-card__badge status status--{{item.status}}">{{item.statusLabel}}</view>
            <view
              wx:if="{{item.status === 'failed'}}"
              class="work-card__delete"
              data-id="{{item.id}}"
              catchtap="deleteFailedJob"
            >删除</view>
          </view>
          <view class="work-card__meta">
            <text class="work-card__name">{{item.templateName}}</text>
            <view class="work-card__sub-row">
              <text class="work-card__sub">{{item.relativeTime}} · {{item.assetIds.length || 0}} 张</text>
              <view wx:if="{{item.status === 'succeeded'}}" class="work-card__flowers">
                <image class="work-card__flower-icon" src="/assets/icons/flower-gift-active.png" mode="aspectFit"></image>
                <text>{{item.flowerCount || item.likeCount || 0}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
      <view class="works-col">
        <view
          wx:for="{{rightJobs}}"
          wx:key="id"
          class="work-card {{item.status === 'failed' ? 'work-card--failed' : ''}}"
          data-id="{{item.id}}"
          bindtap="openJob"
        >
          <view class="work-card__media" style="background: {{item.templatePalette || '#ebe6e8'}}">
            <image
              wx:if="{{item.coverUrl}}"
              class="work-card__cover"
              src="{{item.coverUrl}}"
              mode="widthFix"
              lazy-load
            ></image>
            <view wx:else class="work-card__placeholder">
              <text>{{item.templateShortName}}</text>
            </view>
            <view class="work-card__badge status status--{{item.status}}">{{item.statusLabel}}</view>
            <view
              wx:if="{{item.status === 'failed'}}"
              class="work-card__delete"
              data-id="{{item.id}}"
              catchtap="deleteFailedJob"
            >删除</view>
          </view>
          <view class="work-card__meta">
            <text class="work-card__name">{{item.templateName}}</text>
            <view class="work-card__sub-row">
              <text class="work-card__sub">{{item.relativeTime}} · {{item.assetIds.length || 0}} 张</text>
              <view wx:if="{{item.status === 'succeeded'}}" class="work-card__flowers">
                <image class="work-card__flower-icon" src="/assets/icons/flower-gift-active.png" mode="aspectFit"></image>
                <text>{{item.flowerCount || item.likeCount || 0}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
    <view wx:if="{{listFooter}}" class="list-footer">{{listFooter}}</view>
  </block>

  <view wx:else class="empty empty-work">
    <view class="empty-mark">
      <view class="empty-flower-dot"></view>
      <text>画</text>
    </view>
    <view class="empty-title">还没有作品</view>
    <view class="empty-sub">选一个喜欢的风格，制作第一组照片</view>
    <button class="primary-button" bindtap="goCreate">去创作</button>
  </view>
</view>

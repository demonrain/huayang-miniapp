<view class="page history-page page-enter" style="padding-top: {{navSpacer}}rpx">
  <custom-nav credits="{{user ? user.credits : null}}"></custom-nav>

  <view class="history-heading">
    <view>
      <view class="history-kicker">MY GARDEN</view>
      <view class="section-title__main">我的作品花园</view>
      <view class="section-title__sub">每一次心动，都好好收藏</view>
    </view>
    <view class="album-count">{{jobs.length}} 组</view>
  </view>

  <view wx:if="{{!isLoggedIn && !loading}}" class="empty empty-work">
    <view class="empty-mark">
      <view class="empty-flower-dot"></view>
      <text>登</text>
    </view>
    <view class="empty-title">登录后查看作品</view>
    <view class="empty-sub">游客可以先逛逛模板，登录后保存你的花园</view>
    <button class="primary-button" bindtap="doLogin">微信登录</button>
  </view>

  <view wx:elif="{{loading}}" class="works-grid">
    <view wx:for="{{[1,2,3,4]}}" wx:key="*this" class="work-item skeleton"></view>
  </view>

  <view wx:elif="{{jobs.length}}" class="works-grid">
    <view
      wx:for="{{jobs}}"
      wx:key="id"
      class="work-item"
      data-id="{{item.id}}"
      bindtap="openJob"
    >
      <image
        wx:if="{{item.coverUrl}}"
        class="work-item__cover"
        src="{{item.coverUrl}}"
        mode="widthFix"
      ></image>
      <view wx:else class="work-item__placeholder" style="background: {{item.templatePalette}}">
        <text>{{item.templateShortName}}</text>
      </view>
      <view class="work-item__badge status status--{{item.status}}">{{item.statusLabel}}</view>
      <view class="work-item__meta">
        <text class="work-item__name">{{item.templateName}}</text>
        <text class="work-item__sub">{{item.relativeTime}} · {{item.assetIds.length}} 张</text>
      </view>
    </view>
  </view>

  <view wx:else class="empty empty-work">
    <view class="empty-mark">
      <view class="empty-flower-dot"></view>
      <text>画</text>
    </view>
    <view class="empty-title">还没有作品</view>
    <view class="empty-sub">选一个喜欢的风格，制作第一组照片</view>
    <button class="primary-button" bindtap="goCreate">去创作</button>
  </view>
</view>

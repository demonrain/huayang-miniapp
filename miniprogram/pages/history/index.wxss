.history-heading {
  min-height: 130rpx;
  margin: 6rpx 0 28rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.history-kicker {
  margin-bottom: 8rpx;
  color: var(--coral);
  font-family: Georgia, serif;
  font-size: 17rpx;
  letter-spacing: 0;
}

.history-heading .section-title__sub {
  margin-top: 9rpx;
}

.album-count {
  margin-bottom: 5rpx;
  padding: 8rpx 13rpx;
  background: var(--mint-soft);
  border-radius: 8rpx;
  color: var(--green);
  font-size: 19rpx;
}

/* POC-like works garden: 2-col masonry-ish full covers */
.works-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  align-items: start;
}

.work-item {
  position: relative;
  margin: 0;
  padding: 0;
  overflow: hidden;
  background: #ebe6e8;
  border-radius: 14rpx;
  box-shadow: 0 10rpx 24rpx rgba(108, 81, 92, 0.08);
}

.work-item__cover {
  display: block;
  width: 100%;
  vertical-align: top;
}

.work-item__placeholder {
  width: 100%;
  min-height: 360rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 28rpx;
  color: #fff;
  font-family: "Kaiti SC", "STKaiti", serif;
  font-size: 36rpx;
  font-weight: 700;
}

.work-item:nth-child(3n + 2) .work-item__placeholder {
  min-height: 300rpx;
}

.work-item__badge {
  position: absolute;
  top: 14rpx;
  left: 14rpx;
  z-index: 2;
}

.work-item__meta {
  position: absolute;
  right: 14rpx;
  bottom: 14rpx;
  left: 14rpx;
  z-index: 2;
  padding: 12rpx 14rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 10rpx;
}

.work-item__name {
  display: block;
  overflow: hidden;
  color: var(--ink);
  font-size: 24rpx;
  font-weight: 650;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.work-item__sub {
  display: block;
  margin-top: 4rpx;
  color: var(--muted);
  font-size: 18rpx;
}

.status {
  flex: none;
  padding: 5rpx 10rpx;
  background: rgba(244, 239, 240, 0.95);
  border-radius: 8rpx;
  color: var(--muted);
  font-size: 18rpx;
}

.status--succeeded {
  background: rgba(233, 247, 242, 0.96);
  color: var(--green);
}

.status--failed {
  background: rgba(255, 240, 237, 0.96);
  color: #c56f60;
}

.status--processing,
.status--queued {
  background: rgba(255, 249, 232, 0.96);
  color: #b08a2e;
}

.skeleton {
  min-height: 360rpx;
  border-radius: 14rpx;
}

.empty-mark {
  position: relative;
  width: 110rpx;
  height: 110rpx;
  margin: 0 auto 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--pink-soft);
  border: 2rpx solid #f4dfe3;
  border-radius: 50%;
  color: var(--coral);
  font-family: "Kaiti SC", "STKaiti", serif;
  font-size: 44rpx;
}

.empty-flower-dot {
  position: absolute;
  top: 7rpx;
  right: 7rpx;
  width: 28rpx;
  height: 28rpx;
  background: var(--yellow);
  border: 5rpx solid #fff;
  border-radius: 50%;
}

.empty-title {
  color: var(--ink);
  font-size: 29rpx;
  font-weight: 650;
}

.empty-sub {
  margin: 12rpx 0 34rpx;
  font-size: 21rpx;
}

.empty-work .primary-button {
  width: 280rpx;
  margin: 0 auto;
}

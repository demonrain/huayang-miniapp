.history-page {
  padding-bottom: calc(env(safe-area-inset-bottom) + 48rpx);
}

.history-heading {
  min-height: 130rpx;
  margin: 6rpx 0 28rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.list-footer {
  padding: 28rpx 16rpx 12rpx;
  text-align: center;
  color: var(--muted);
  font-size: 22rpx;
}

.history-kicker {
  margin-bottom: 8rpx;
  color: var(--coral);
  font-family: Georgia, serif;
  font-size: 17rpx;
  letter-spacing: 0;
}

.history-heading .section-title__sub {
  margin-top: 9rpx;
}

.album-count {
  margin-bottom: 5rpx;
  padding: 8rpx 13rpx;
  background: var(--mint-soft);
  border-radius: 8rpx;
  color: var(--green);
  font-size: 19rpx;
}

/* Two-column waterfall */
.works-waterfall {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.works-col {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.work-card {
  overflow: hidden;
  background: #fff;
  border: 2rpx solid #f0e8ea;
  border-radius: 16rpx;
  box-shadow: 0 10rpx 24rpx rgba(108, 81, 92, 0.08);
}

.work-card__media {
  position: relative;
  width: 100%;
  overflow: hidden;
  background: #ebe6e8;
}

.work-card__cover {
  display: block;
  width: 100%;
  vertical-align: top;
}

.work-card__placeholder {
  width: 100%;
  min-height: 280rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 24rpx;
  color: #fff;
  font-family: "Kaiti SC", "STKaiti", serif;
  font-size: 36rpx;
  font-weight: 700;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.18);
}

.work-card__badge {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  z-index: 2;
}

.work-card__delete {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  z-index: 3;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.95);
  border: 2rpx solid #f0d5d0;
  border-radius: 999rpx;
  color: #c56f60;
  font-size: 20rpx;
  font-weight: 650;
  box-shadow: 0 6rpx 14rpx rgba(108, 81, 92, 0.12);
}

.work-card--failed .work-card__cover {
  opacity: 0.72;
  filter: grayscale(0.15);
}

.work-card__meta {
  padding: 14rpx 16rpx 16rpx;
}

.work-card__name {
  display: block;
  overflow: hidden;
  color: var(--ink);
  font-size: 24rpx;
  font-weight: 650;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.work-card__sub {
  display: block;
  margin-top: 6rpx;
  color: var(--muted);
  font-size: 18rpx;
}

.status {
  flex: none;
  padding: 5rpx 10rpx;
  background: rgba(244, 239, 240, 0.95);
  border-radius: 8rpx;
  color: var(--muted);
  font-size: 18rpx;
}

.status--succeeded {
  background: rgba(233, 247, 242, 0.96);
  color: var(--green);
}

.status--failed {
  background: rgba(255, 240, 237, 0.96);
  color: #c56f60;
}

.status--processing,
.status--queued {
  background: rgba(255, 249, 232, 0.96);
  color: #b08a2e;
}

.skeleton {
  border-radius: 16rpx;
  background: linear-gradient(90deg, #f4eef0 25%, #faf6f7 50%, #f4eef0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.2s ease infinite;
}

@keyframes shimmer {
  0% { background-position: 100% 0; }
  100% { background-position: -100% 0; }
}

.empty-mark {
  position: relative;
  width: 110rpx;
  height: 110rpx;
  margin: 0 auto 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--pink-soft);
  border: 2rpx solid #f4dfe3;
  border-radius: 50%;
  color: var(--coral);
  font-family: "Kaiti SC", "STKaiti", serif;
  font-size: 44rpx;
}

.empty-flower-dot {
  position: absolute;
  top: 7rpx;
  right: 7rpx;
  width: 28rpx;
  height: 28rpx;
  background: var(--yellow);
  border: 5rpx solid #fff;
  border-radius: 50%;
}

.empty-title {
  color: var(--ink);
  font-size: 29rpx;
  font-weight: 650;
}

.empty-sub {
  margin: 12rpx 0 34rpx;
  font-size: 21rpx;
}

.empty-work .primary-button {
  width: 280rpx;
  margin: 0 auto;
}

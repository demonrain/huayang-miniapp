<view class="page home-page page-enter" style="padding-top: {{navSpacer}}rpx">
  <custom-nav credits="{{user ? user.credits : null}}"></custom-nav>

  <swiper
    wx:if="{{banners.length}}"
    class="banner-swiper"
    indicator-dots="{{banners.length > 1}}"
    indicator-color="rgba(255,255,255,.55)"
    indicator-active-color="#ffffff"
    autoplay="{{bannerAutoplay}}"
    interval="{{bannerInterval}}"
    circular="{{bannerCircular}}"
  >
    <swiper-item wx:for="{{banners}}" wx:key="id">
      <view class="welcome-card banner-card" style="background: {{item.palette}}" data-path="{{item.targetPath}}" bindtap="openBanner">
        <image wx:if="{{item.imageUrl}}" class="banner-image" src="{{item.imageUrl}}" mode="aspectFill"></image>
        <view wx:if="{{item.imageUrl}}" class="banner-shade"></view>
        <view class="welcome-copy banner-copy {{item.imageUrl ? 'banner-copy--image' : ''}}">
          <view class="welcome-kicker">{{item.badge || '今日灵感'}}</view>
          <view class="welcome-title">{{item.title}}</view>
          <view class="banner-subtitle">{{item.subtitle}}</view>
        </view>
      </view>
    </swiper-item>
  </swiper>

  <view wx:else class="welcome-card">
    <view class="welcome-copy">
      <view class="welcome-kicker">今日灵感</view>
      <view class="welcome-title">把喜欢的瞬间，做成专属画报</view>
      <view class="welcome-gift">
        <text>新用户礼遇</text>
        <text class="welcome-gift__value">{{welcomeCredits}} 积分</text>
      </view>
    </view>
    <view class="welcome-collage">
      <view class="collage-paper collage-paper--back"></view>
      <view class="collage-paper collage-paper--front">
        <view class="collage-sky"></view>
        <view class="collage-hill"></view>
        <view class="collage-sun"></view>
      </view>
      <view class="collage-tape"></view>
      <view class="collage-spark">＋</view>
    </view>
  </view>

  <view wx:if="{{latestAnnouncement}}" class="announcement-entry" bindtap="openLatestAnnouncement" hover-class="announcement-entry--hover">
    <view class="announcement-entry__badge">公告</view>
    <view class="announcement-entry__copy">
      <view class="announcement-entry__title">{{latestAnnouncement.title}}</view>
      <view class="announcement-entry__content">{{latestAnnouncement.content}}</view>
    </view>
    <view class="announcement-entry__arrow">›</view>
  </view>

  <view class="section-title">
    <view>
      <view class="section-title__main">挑一款心动风格</view>
      <view class="section-kicker">让照片拥有新的小情绪</view>
    </view>
    <view class="section-title__sub">2 积分起</view>
  </view>

  <scroll-view class="category-scroll" scroll-x enhanced show-scrollbar="false">
    <view class="category-row">
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="category {{activeCategory === item.id ? 'category--active' : ''}}"
        data-id="{{item.id}}"
        bindtap="selectCategory"
        hover-class="category--hover"
      >{{item.name}}</view>
    </view>
  </scroll-view>

  <view wx:if="{{loading}}" class="home-loading">
    <view class="home-loading__flower">
      <view class="home-loading__petal home-loading__petal--1"></view>
      <view class="home-loading__petal home-loading__petal--2"></view>
      <view class="home-loading__petal home-loading__petal--3"></view>
      <view class="home-loading__petal home-loading__petal--4"></view>
      <view class="home-loading__dot"></view>
    </view>
    <view class="home-loading__title">风格正在开花</view>
    <view class="home-loading__tip">{{loadingTip}}</view>
    <view class="template-grid home-loading__grid">
      <view wx:for="{{[1,2,3,4]}}" wx:key="*this" class="template-card skeleton"></view>
    </view>
  </view>

  <view wx:else class="template-grid">
    <view
      wx:for="{{filteredTemplates}}"
      wx:key="id"
      class="template-card"
      data-id="{{item.id}}"
      bindtap="startCreate"
    >
      <view class="template-art" style="background: {{item.palette}}">
        <image
          wx:if="{{item.coverUrl}}"
          class="template-cover"
          src="{{item.coverUrl}}"
          mode="aspectFit"
          lazy-load
        ></image>
        <block wx:else>
          <view class="art-paper">
            <view class="art-window">
              <view class="art-land"></view>
              <view class="art-light"></view>
            </view>
          </view>
          <view class="art-tape"></view>
          <view class="art-flower">
            <view class="art-petal art-petal--one"></view>
            <view class="art-petal art-petal--two"></view>
            <view class="art-petal art-petal--three"></view>
            <view class="art-petal art-petal--four"></view>
            <view class="art-flower-dot"></view>
          </view>
        </block>
        <view class="art-title">{{item.shortName}}</view>
        <view wx:if="{{item.badge}}" class="art-badge">{{item.badge}}</view>
      </view>
      <view class="template-meta">
        <view class="template-copy">
          <view class="template-name">{{item.name}}</view>
          <view class="template-desc">{{item.description}}</view>
        </view>
        <view class="template-side">
          <view class="template-cost">{{item.cost}} 积分</view>
          <view class="template-popularity">人气 {{item.popularityText}}</view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{!loading && !filteredTemplates.length}}" class="empty">这个分类的模板还在准备中</view>

  <view wx:if="{{!loading && filteredTemplates.length && listFooter}}" class="list-footer">{{listFooter}}</view>

  <!-- Admin in-app announcement -->
  <view wx:if="{{showAnnouncement && announcement}}" class="announce-mask" catchtouchmove="noop">
    <view class="announce-sheet">
      <view class="announce-kicker">公告</view>
      <view class="announce-title">{{announcement.title}}</view>
      <view class="announce-body">{{announcement.content}}</view>
      <button class="primary-button announce-btn" bindtap="dismissAnnouncementOnce">我知道了</button>
      <view class="announce-skip" bindtap="dismissAnnouncementForever">不再提示</view>
    </view>
  </view>

  <!-- First-time onboarding: invite into interactive fake-gen tour -->
  <view wx:if="{{showOnboarding}}" class="onboard-mask" catchtouchmove="noop">
    <view class="onboard-sheet">
      <view class="onboard-kicker">游客模拟创作</view>
      <view class="onboard-title">不登录，也能先体验一次生图</view>
      <view class="onboard-lead">
        我们已经准备好示例照片，接下来会带你走过模板详情、选图、生成进度和结果页。全程不登录、不上传、不扣积分。
      </view>
      <view class="onboard-steps onboard-steps--compact">
        <view class="onboard-step">
          <view class="onboard-step__num">1</view>
          <view class="onboard-step__body">
            <view class="onboard-step__title">看模板</view>
          </view>
        </view>
        <view class="onboard-step">
          <view class="onboard-step__num">2</view>
          <view class="onboard-step__body">
            <view class="onboard-step__title">用示例图</view>
          </view>
        </view>
        <view class="onboard-step">
          <view class="onboard-step__num">3</view>
          <view class="onboard-step__body">
            <view class="onboard-step__title">看进度</view>
          </view>
        </view>
        <view class="onboard-step">
          <view class="onboard-step__num">4</view>
          <view class="onboard-step__body">
            <view class="onboard-step__title">看结果</view>
          </view>
        </view>
      </view>
      <view class="onboard-gift">新用户赠送 {{welcomeCredits}} 积分 · 练习不消耗</view>
      <button class="primary-button onboard-cta" bindtap="finishOnboarding">开始模拟生图</button>
      <view class="onboard-skip" bindtap="skipOnboarding">我先随便看看</view>
    </view>
  </view>
</view>

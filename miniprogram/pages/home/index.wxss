.home-page {
  padding-bottom: 24rpx;
}

.banner-swiper {
  height: 220rpx;
  margin-top: 8rpx;
}

.banner-swiper .welcome-card {
  height: 100%;
  margin-top: 0;
}

.banner-image,
.banner-shade {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.banner-shade {
  z-index: 1;
  background: linear-gradient(90deg, rgba(42, 47, 45, .62), rgba(42, 47, 45, .08));
}

.banner-copy { width: 72%; max-width: 520rpx; }
.banner-copy--image { color: #fff; }
.banner-copy--image .welcome-kicker,
.banner-copy--image .welcome-title,
.banner-copy--image .banner-subtitle { color: #fff; }

.banner-subtitle {
  margin-top: 16rpx;
  color: #71857f;
  font-size: 20rpx;
  line-height: 1.5;
}

.welcome-card {
  position: relative;
  height: 220rpx;
  margin-top: 8rpx;
  padding: 24rpx 24rpx;
  display: flex;
  overflow: hidden;
  background: var(--mint-soft);
  border: 2rpx solid #d9eee7;
  border-radius: 16rpx;
}

.welcome-card::before {
  content: '';
  position: absolute;
  top: -16rpx;
  left: 42%;
  width: 2rpx;
  height: 340rpx;
  background: rgba(88, 173, 153, 0.14);
  transform: rotate(12deg);
}

.welcome-copy {
  position: relative;
  z-index: 2;
  width: 72%;
  max-width: 520rpx;
}

.welcome-kicker {
  color: var(--green);
  font-size: 20rpx;
  font-weight: 600;
}

.welcome-title {
  margin-top: 10rpx;
  color: #385c54;
  font-family: "Kaiti SC", "STKaiti", "Songti SC", serif;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
  white-space: nowrap;
}

.welcome-gift {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #71857f;
  font-size: 19rpx;
}

.welcome-gift__value {
  padding: 6rpx 12rpx;
  background: #fff;
  border-radius: 10rpx;
  color: var(--coral);
  font-weight: 700;
}

.welcome-collage {
  position: absolute;
  right: 12rpx;
  bottom: 0;
  width: 270rpx;
  height: 270rpx;
}

.collage-paper {
  position: absolute;
  width: 150rpx;
  height: 192rpx;
  padding: 12rpx;
  background: #fff;
  border-radius: 8rpx;
  box-shadow: 0 12rpx 24rpx rgba(70, 112, 102, 0.12);
}

.collage-paper--back {
  right: 46rpx;
  bottom: 22rpx;
  background: #ffd5dc;
  transform: rotate(12deg);
}

.collage-paper--front {
  right: 60rpx;
  bottom: 18rpx;
  overflow: hidden;
  transform: rotate(-7deg);
}

.collage-sky {
  height: 112rpx;
  background: #b9deda;
}

.collage-hill {
  position: absolute;
  right: -18rpx;
  bottom: 24rpx;
  width: 150rpx;
  height: 78rpx;
  background: #91c9ae;
  border-radius: 70% 0 0 0;
}

.collage-sun {
  position: absolute;
  top: 38rpx;
  right: 32rpx;
  width: 34rpx;
  height: 34rpx;
  background: var(--yellow);
  border-radius: 50%;
}

.collage-tape {
  position: absolute;
  top: 35rpx;
  right: 93rpx;
  z-index: 3;
  width: 72rpx;
  height: 24rpx;
  background: rgba(255, 217, 120, 0.8);
  transform: rotate(7deg);
}

.collage-spark {
  position: absolute;
  top: 74rpx;
  right: 18rpx;
  color: var(--coral);
  font-size: 42rpx;
  font-weight: 300;
  transform: rotate(16deg);
}

.section-kicker {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 20rpx;
}

.category-scroll {
  width: 100%;
  white-space: nowrap;
}

.category-row {
  display: inline-flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: center;
  gap: 12rpx;
  padding-bottom: 12rpx;
  /* Allow chips wider than viewport to scroll fully */
  width: max-content;
  min-width: 100%;
  box-sizing: border-box;
}

.category {
  flex: none;
  width: auto;
  max-width: none;
  min-width: 0;
  height: auto;
  min-height: 52rpx;
  margin: 0;
  padding: 10rpx 24rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: 999rpx;
  color: var(--muted);
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.35;
  white-space: nowrap;
  overflow: visible;
  text-overflow: clip;
}

.category--hover {
  opacity: 0.85;
}

.category--active {
  background: var(--pink-soft);
  border-color: #f2a4b1;
  color: var(--coral);
  font-weight: 650;
}

/* Flex grid avoids WeChat real-device CSS-grid + button height bugs that cause card overlap */
.template-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 12rpx;
  width: 100%;
  box-sizing: border-box;
}

.template-card {
  width: calc((100% - 16rpx) / 2);
  margin: 0;
  padding: 0;
  overflow: hidden;
  background: #fff;
  border: 2rpx solid rgba(240, 227, 229, 0.9);
  border-radius: 16rpx;
  box-shadow: 0 10rpx 24rpx rgba(116, 83, 96, 0.07);
  text-align: left;
  line-height: 1.3;
  box-sizing: border-box;
  animation: card-in 0.45s ease-out both;
}

.template-card:nth-child(2) { animation-delay: 0.05s; }
.template-card:nth-child(3) { animation-delay: 0.1s; }
.template-card:nth-child(4) { animation-delay: 0.15s; }

/* Fixed square cover area: full image via aspectFit, no crop, stable row height */
.template-art {
  position: relative;
  width: 100%;
  height: 0;
  padding-bottom: 100%;
  overflow: hidden;
  background: #f4ecee;
}

.template-cover {
  position: absolute;
  inset: 0;
  display: block;
  width: 100%;
  height: 100%;
}

.art-paper {
  position: absolute;
  top: 38rpx;
  left: 50%;
  width: 160rpx;
  height: 180rpx;
  padding: 12rpx 12rpx 30rpx;
  background: #fffdfb;
  border-radius: 6rpx;
  box-shadow: 0 10rpx 22rpx rgba(82, 67, 72, 0.12);
  transform: translateX(-50%) rotate(-5deg);
}

.art-window {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
  background: rgba(255,255,255,0.45);
}

.art-land {
  position: absolute;
  right: -22rpx;
  bottom: -14rpx;
  width: 138rpx;
  height: 88rpx;
  background: rgba(77, 157, 132, 0.38);
  border-radius: 70% 0 0 0;
}

.art-light {
  position: absolute;
  top: 28rpx;
  right: 26rpx;
  width: 30rpx;
  height: 30rpx;
  background: rgba(255, 234, 153, 0.95);
  border-radius: 50%;
}

.art-tape {
  position: absolute;
  top: 28rpx;
  left: calc(50% - 40rpx);
  z-index: 2;
  width: 84rpx;
  height: 24rpx;
  background: rgba(255, 244, 207, 0.86);
  transform: rotate(4deg);
}

.art-flower {
  position: absolute;
  right: 22rpx;
  bottom: 18rpx;
  z-index: 3;
  width: 54rpx;
  height: 54rpx;
}

.art-petal {
  position: absolute;
  width: 24rpx;
  height: 24rpx;
  background: #fff;
  border-radius: 50%;
}

.art-petal--one { top: 0; left: 15rpx; }
.art-petal--two { top: 15rpx; right: 0; }
.art-petal--three { bottom: 0; left: 15rpx; }
.art-petal--four { top: 15rpx; left: 0; }

.art-flower-dot {
  position: absolute;
  top: 18rpx;
  left: 18rpx;
  z-index: 2;
  width: 18rpx;
  height: 18rpx;
  background: var(--yellow);
  border-radius: 50%;
}

.art-title {
  position: absolute;
  left: 18rpx;
  bottom: 18rpx;
  z-index: 4;
  padding: 7rpx 12rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 8rpx;
  color: #5d5056;
  font-family: "Kaiti SC", "STKaiti", serif;
  font-size: 27rpx;
  font-weight: 700;
}

.art-badge {
  position: absolute;
  top: 14rpx;
  right: 14rpx;
  z-index: 4;
  padding: 7rpx 11rpx;
  background: var(--coral);
  border-radius: 8rpx;
  color: #fff;
  font-size: 17rpx;
}

.template-meta {
  min-height: 0;
  height: auto;
  padding: 10rpx 12rpx 12rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 6rpx;
  box-sizing: border-box;
}

.template-copy {
  min-width: 0;
  flex: 1;
}

.template-name {
  overflow: hidden;
  font-size: 24rpx;
  font-weight: 650;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.template-desc {
  margin-top: 4rpx;
  overflow: hidden;
  color: var(--muted);
  font-size: 17rpx;
  line-height: 1.3;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.template-tags {
  height: 32rpx;
  margin-top: 9rpx;
  display: flex;
  gap: 6rpx;
  overflow: hidden;
}

.template-tags text {
  padding: 3rpx 8rpx;
  flex: none;
  background: var(--pink-soft);
  border-radius: 6rpx;
  color: var(--coral);
  font-size: 16rpx;
  line-height: 26rpx;
}

.template-side {
  flex: none;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
  padding-top: 2rpx;
}

.template-cost {
  color: var(--coral);
  font-size: 17rpx;
  line-height: 1.2;
  white-space: nowrap;
}

.template-popularity {
  color: var(--muted);
  font-size: 15rpx;
  line-height: 1.2;
  white-space: nowrap;
}

.template-arrow {
  width: 34rpx;
  height: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--mint-soft);
  border-radius: 50%;
  color: var(--green);
  font-size: 30rpx;
  font-weight: 300;
  line-height: 34rpx;
}

.skeleton {
  min-height: 420rpx;
}

.home-loading {
  margin-top: 8rpx;
}

.home-loading__flower {
  position: relative;
  width: 88rpx;
  height: 88rpx;
  margin: 12rpx auto 18rpx;
  animation: home-flower-spin 3.8s linear infinite;
}

.home-loading__petal {
  position: absolute;
  width: 34rpx;
  height: 48rpx;
  background: var(--pink);
  border-radius: 50%;
  opacity: 0.9;
}

.home-loading__petal--1 { top: 0; left: 27rpx; }
.home-loading__petal--2 { top: 20rpx; right: 0; transform: rotate(90deg); }
.home-loading__petal--3 { bottom: 0; left: 27rpx; transform: rotate(180deg); }
.home-loading__petal--4 { top: 20rpx; left: 0; transform: rotate(270deg); }

.home-loading__dot {
  position: absolute;
  top: 30rpx;
  left: 30rpx;
  z-index: 2;
  width: 28rpx;
  height: 28rpx;
  background: var(--yellow);
  border: 4rpx solid #fff;
  border-radius: 50%;
}

.home-loading__title {
  text-align: center;
  color: var(--coral);
  font-family: "Kaiti SC", "STKaiti", serif;
  font-size: 32rpx;
  font-weight: 700;
}

.home-loading__tip {
  margin: 10rpx 0 28rpx;
  min-height: 40rpx;
  text-align: center;
  color: var(--muted);
  font-size: 24rpx;
  line-height: 1.5;
}

.home-loading__grid {
  margin-top: 0;
  opacity: 0.72;
}

@keyframes home-flower-spin {
  to { transform: rotate(360deg); }
}

@keyframes card-in {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* First-time onboarding overlay */
.onboard-mask {
  position: fixed;
  inset: 0;
  z-index: 20000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 32rpx 28rpx calc(32rpx + env(safe-area-inset-bottom));
  background: rgba(48, 40, 44, 0.48);
  box-sizing: border-box;
}

.onboard-sheet {
  width: 100%;
  max-width: 680rpx;
  padding: 36rpx 32rpx 28rpx;
  background: #fff;
  border-radius: 24rpx 24rpx 20rpx 20rpx;
  box-shadow: 0 -12rpx 48rpx rgba(80, 60, 70, 0.18);
}

.onboard-kicker {
  color: var(--coral);
  font-family: Georgia, serif;
  font-size: 18rpx;
  letter-spacing: 2rpx;
}

.onboard-title {
  margin-top: 8rpx;
  color: var(--ink);
  font-size: 36rpx;
  font-weight: 700;
}

.onboard-steps {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.onboard-step {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.onboard-step__num {
  width: 48rpx;
  height: 48rpx;
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #ffe8ec, #fff6e8);
  border-radius: 50%;
  color: var(--coral);
  font-family: Georgia, serif;
  font-size: 24rpx;
  font-weight: 700;
}

.onboard-step__title {
  font-size: 28rpx;
  font-weight: 650;
}

.onboard-step__text {
  margin-top: 4rpx;
  color: var(--muted);
  font-size: 22rpx;
  line-height: 1.5;
}

.onboard-gift {
  margin: 28rpx 0 20rpx;
  padding: 16rpx 18rpx;
  background: var(--mint-soft);
  border-radius: 12rpx;
  color: var(--green);
  font-size: 22rpx;
  text-align: center;
}

.onboard-cta {
  width: 100%;
}

.onboard-skip {
  margin-top: 18rpx;
  text-align: center;
  color: var(--muted);
  font-size: 24rpx;
  padding: 12rpx;
}

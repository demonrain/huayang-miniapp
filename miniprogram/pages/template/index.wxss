.template-page {
  padding-left: 0;
  padding-right: 0;
  padding-bottom: calc(env(safe-area-inset-bottom) + 180rpx);
}

.detail-cover {
  position: relative;
  height: 720rpx;
  margin: 0 0 0;
  overflow: hidden;
  background: var(--pink-soft);
}

.detail-cover__image {
  display: block;
  width: 100%;
  height: 100%;
}

.detail-cover__fallback {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 80rpx;
}

.fallback-paper {
  position: absolute;
  top: 160rpx;
  left: 50%;
  width: 280rpx;
  height: 340rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 14rpx solid #fff;
  border-radius: 8rpx;
  box-shadow: 0 18rpx 40rpx rgba(90, 70, 80, 0.16);
  transform: translateX(-50%) rotate(-6deg);
}

.fallback-tape {
  position: absolute;
  top: 148rpx;
  left: 50%;
  z-index: 2;
  width: 120rpx;
  height: 34rpx;
  background: rgba(255, 235, 170, 0.92);
  transform: translateX(-50%) rotate(4deg);
}

.fallback-title {
  position: relative;
  z-index: 3;
  padding: 10rpx 18rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 10rpx;
  color: #5b4d53;
  font-family: "Kaiti SC", "STKaiti", serif;
  font-size: 40rpx;
  font-weight: 700;
}

.detail-cover__badge {
  position: absolute;
  right: 28rpx;
  bottom: 28rpx;
  z-index: 2;
  padding: 10rpx 16rpx;
  background: var(--coral);
  border-radius: 10rpx;
  color: #fff;
  font-size: 22rpx;
  font-weight: 650;
}

.detail-body {
  padding: 36rpx 30rpx 40rpx;
  background: transparent;
}

.detail-eyebrow {
  color: var(--coral);
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.detail-title {
  margin-top: 12rpx;
  font-family: "Kaiti SC", "STKaiti", "Songti SC", serif;
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.25;
}

.detail-desc {
  margin-top: 16rpx;
  color: var(--muted);
  font-size: 26rpx;
  line-height: 1.7;
}

.detail-meta {
  margin-top: 18rpx;
  display: flex;
  gap: 24rpx;
  color: var(--muted);
  font-size: 22rpx;
}

.tag-row {
  margin-top: 22rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-row text {
  padding: 10rpx 16rpx;
  background: var(--pink-soft);
  border-radius: 10rpx;
  color: var(--coral);
  font-size: 20rpx;
}

.sample-heading {
  margin-top: 48rpx;
}

.sample-heading__main {
  font-size: 34rpx;
  font-weight: 650;
}

.sample-heading__sub {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 22rpx;
}

.sample-scroll {
  margin-top: 22rpx;
  width: 100%;
}

/* ≤3：三等分网格；>3：横向滚动，单卡约 1/3 宽可露半张 */
.sample-strip {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.sample-strip--scroll {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  gap: 14rpx;
  width: max-content;
  padding-right: 8rpx;
  box-sizing: border-box;
}

.sample-scroll--many .sample-card {
  width: 210rpx;
  flex: none;
}

.sample-card {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  overflow: hidden;
  border-radius: 12rpx;
  box-shadow: 0 8rpx 20rpx rgba(108, 82, 92, 0.08);
}

.sample-card image {
  display: block;
  width: 100%;
  height: 100%;
}

.sample-card__label {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  padding: 6rpx 10rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 8rpx;
  color: #5d5056;
  font-size: 20rpx;
  font-weight: 650;
}

.detail-action {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  min-height: 148rpx;
  padding: 22rpx 30rpx calc(env(safe-area-inset-bottom) + 22rpx);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  background: rgba(255, 255, 255, 0.97);
  border-top: 2rpx solid var(--line);
  box-shadow: 0 -10rpx 30rpx rgba(108, 80, 91, 0.06);
}

.detail-action__label {
  color: var(--muted);
  font-size: 20rpx;
}

.detail-action__cost {
  margin-top: 4rpx;
  color: var(--coral);
  font-family: Georgia, serif;
  font-size: 40rpx;
  font-weight: 700;
}

.detail-action__cost text {
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx;
  font-weight: 400;
}

.detail-action__button {
  width: 340rpx;
  height: 88rpx;
  margin: 0;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: var(--coral);
  border-radius: 16rpx;
  box-shadow: 0 12rpx 26rpx rgba(231, 109, 130, 0.22);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
}

.detail-action__icon {
  width: 34rpx;
  height: 34rpx;
  flex: none;
}

.detail-action__button::after {
  border: 0;
}

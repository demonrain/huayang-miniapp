/* Page locks; only .ledger-scroll scrolls */
.redeem-page {
  height: 100vh;
  max-height: 100vh;
  padding-bottom: 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-sizing: border-box;
}

.redeem-top {
  flex: none;
  padding-bottom: 4rpx;
}

.redeem-hero {
  margin-top: 8rpx;
  padding: 8rpx 4rpx 16rpx;
}

.redeem-kicker {
  color: var(--coral);
  font-family: Georgia, serif;
  font-size: 17rpx;
  letter-spacing: 2rpx;
}

.redeem-title {
  margin-top: 8rpx;
  font-size: 40rpx;
  font-weight: 700;
}

.redeem-sub {
  margin-top: 10rpx;
  color: var(--muted);
  font-size: 22rpx;
  line-height: 1.55;
}

.redeem-card {
  padding: 24rpx 26rpx;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
  box-shadow: 0 12rpx 32rpx rgba(107, 80, 90, 0.06);
}

.redeem-label {
  color: var(--ink);
  font-size: 24rpx;
  font-weight: 650;
}

.redeem-input {
  width: 100%;
  height: 88rpx;
  margin-top: 14rpx;
  padding: 0 20rpx;
  background: #faf7f8;
  border: 2rpx solid #f0e3e5;
  border-radius: 14rpx;
  box-sizing: border-box;
  color: var(--ink);
  font-family: Consolas, "SF Mono", monospace;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.redeem-tips {
  margin-top: 14rpx;
  color: var(--muted);
  font-size: 20rpx;
  line-height: 1.65;
}

.redeem-btn {
  margin-top: 22rpx;
  width: 100%;
}

.redeem-balance {
  margin-top: 16rpx;
  padding: 18rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.redeem-balance__label {
  color: var(--muted);
  font-size: 22rpx;
}

.redeem-balance__value {
  color: var(--coral);
  font-family: Georgia, serif;
  font-size: 40rpx;
  font-weight: 700;
}

.ledger-title {
  margin-top: 24rpx;
  margin-bottom: 8rpx;
}

.ledger-guest {
  flex: none;
  margin-bottom: calc(env(safe-area-inset-bottom) + 24rpx);
  padding: 28rpx 24rpx;
  text-align: center;
}

.ledger-guest__text {
  color: var(--muted);
  font-size: 22rpx;
  line-height: 1.55;
}

.ledger-guest__btn {
  margin-top: 20rpx;
  width: 100%;
}

/* Independent scroll area for ledger */
.ledger-scroll {
  flex: 1;
  min-height: 0;
  height: 0;
  margin-bottom: env(safe-area-inset-bottom);
  box-sizing: border-box;
}

.ledger-loading {
  padding: 40rpx 16rpx;
  text-align: center;
  color: var(--muted);
  font-size: 22rpx;
}

.transaction-list {
  overflow: hidden;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(108, 82, 92, 0.04);
}

.transaction-row {
  min-height: 108rpx;
  padding: 20rpx 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  border-bottom: 2rpx solid var(--line);
}

.transaction-row:last-child {
  border-bottom: 0;
}

.transaction-main {
  flex: 1;
  min-width: 0;
}

.transaction-name {
  font-size: 24rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.transaction-time {
  margin-top: 7rpx;
  color: var(--muted);
  font-size: 18rpx;
}

.transaction-amount {
  flex: none;
  color: var(--coral);
  font-family: Georgia, serif;
  font-size: 29rpx;
  font-weight: 700;
}

.transaction-amount--plus {
  color: var(--green);
}

.ledger-empty {
  padding: 48rpx 24rpx;
}

.ledger-footer {
  padding: 20rpx 12rpx 28rpx;
  text-align: center;
  color: var(--muted);
  font-size: 20rpx;
}

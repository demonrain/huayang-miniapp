.balance-panel {
  position: relative;
  min-height: 248rpx;
  padding: 34rpx;
  overflow: hidden;
  background: var(--ink);
  color: #fff;
  border-radius: 8rpx;
}

.balance-panel::after {
  content: '';
  position: absolute;
  right: -50rpx;
  bottom: -76rpx;
  width: 230rpx;
  height: 170rpx;
  border: 28rpx solid var(--coral);
  transform: rotate(-18deg);
}

.balance-label { color: #a8aaa6; font-size: 22rpx; }
.balance-value { margin-top: 10rpx; font-family: Georgia, serif; font-size: 82rpx; font-weight: 700; line-height: 1.1; }
.balance-foot { margin-top: 24rpx; color: #b9bbb7; font-size: 20rpx; }
.balance-stamp { position: absolute; top: 30rpx; right: 28rpx; padding: 8rpx 12rpx; border: 2rpx solid #5d615e; color: #c4c5c2; font-family: "Songti SC", serif; font-size: 18rpx; }

.package-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.package-card {
  position: relative;
  min-width: 0;
  min-height: 198rpx;
  margin: 0;
  padding: 25rpx 20rpx;
  background: var(--surface);
  border: 2rpx solid var(--line);
  text-align: left;
  line-height: 1.35;
}

.package-card--selected {
  background: #edf3ef;
  border: 4rpx solid var(--green);
  padding: 23rpx 18rpx;
}

.package-badge { position: absolute; top: 0; right: 0; padding: 7rpx 10rpx; background: var(--coral); color: #fff; font-size: 17rpx; }
.package-credits { font-size: 30rpx; font-weight: 700; }
.package-credits text { font-size: 20rpx; font-weight: 400; }
.package-price { margin-top: 20rpx; font-family: Georgia, serif; font-size: 44rpx; font-weight: 700; }
.package-price text { margin-right: 3rpx; font-size: 22rpx; }
.package-bonus { margin-top: 10rpx; color: var(--coral); font-size: 18rpx; }
.pay-button { margin-top: 24rpx; }
.pay-note { margin-top: 14rpx; color: var(--muted); font-size: 19rpx; text-align: center; }
.transaction-title { margin-top: 50rpx; }
.transaction-list { background: var(--surface); border: 2rpx solid var(--line); }
.transaction-row { min-height: 106rpx; padding: 20rpx 22rpx; display: flex; align-items: center; justify-content: space-between; border-bottom: 2rpx solid var(--line); }
.transaction-row:last-child { border-bottom: 0; }
.transaction-name { font-size: 25rpx; font-weight: 600; }
.transaction-time { margin-top: 7rpx; color: var(--muted); font-size: 18rpx; }
.transaction-amount { color: var(--coral); font-family: Georgia, serif; font-size: 30rpx; font-weight: 700; }
.transaction-amount--plus { color: var(--green); }


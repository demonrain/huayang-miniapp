<view class="page wallet-page">
  <view class="balance-panel">
    <view class="balance-label">可用积分</view>
    <view class="balance-value">{{user ? user.credits : '--'}}</view>
    <view class="balance-foot">1 张作品约消耗 2–5 积分</view>
    <view class="balance-stamp">画漾积分</view>
  </view>

  <view class="section-title">
    <view class="section-title__main">充值积分</view>
    <view class="section-title__sub">即时到账</view>
  </view>

  <view class="package-grid">
    <button
      wx:for="{{packages}}"
      wx:key="id"
      class="package-card {{selectedId === item.id ? 'package-card--selected' : ''}}"
      data-id="{{item.id}}"
      bindtap="selectPackage"
    >
      <view wx:if="{{item.badge}}" class="package-badge">{{item.badge}}</view>
      <view class="package-credits">{{item.credits}}<text> 积分</text></view>
      <view class="package-price"><text>¥</text>{{item.priceYuan}}</view>
      <view wx:if="{{item.bonus}}" class="package-bonus">含赠送 {{item.bonus}} 积分</view>
    </button>
  </view>

  <button class="primary-button pay-button" loading="{{paying}}" disabled="{{!selectedId || paying}}" bindtap="pay">微信支付</button>
  <view class="pay-note">充值积分仅用于本小程序内的图片生成服务</view>

  <view class="section-title transaction-title">
    <view class="section-title__main">积分明细</view>
  </view>
  <view class="transaction-list">
    <view wx:for="{{transactions}}" wx:key="id" class="transaction-row">
      <view>
        <view class="transaction-name">{{item.title}}</view>
        <view class="transaction-time">{{item.displayTime}}</view>
      </view>
      <view class="transaction-amount {{item.amount > 0 ? 'transaction-amount--plus' : ''}}">{{item.amount > 0 ? '+' : ''}}{{item.amount}}</view>
    </view>
    <view wx:if="{{!transactions.length}}" class="empty">暂无积分记录</view>
  </view>
</view>


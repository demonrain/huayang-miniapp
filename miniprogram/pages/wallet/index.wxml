<view class="page wallet-page page-enter">
  <view class="balance-panel">
    <view class="balance-copy">
      <view class="balance-label">我的灵感积分</view>
      <view class="balance-row"><text class="balance-value">{{user ? user.credits : '--'}}</text><text class="balance-unit">积分</text></view>
      <view class="balance-foot">每张作品约需 2–5 积分</view>
    </view>
    <view class="balance-flower">
      <view class="balance-petal balance-petal--one"></view>
      <view class="balance-petal balance-petal--two"></view>
      <view class="balance-petal balance-petal--three"></view>
      <view class="balance-petal balance-petal--four"></view>
      <view class="balance-flower-dot"></view>
    </view>
    <view class="balance-stamp">XIANGHUI</view>
  </view>

  <view wx:if="{{checkin}}" class="checkin-panel">
    <view>
      <view class="checkin-title">每日签到</view>
      <view class="checkin-sub">今天可领取 {{checkin.reward}} 积分</view>
    </view>
    <button class="checkin-button {{checkin.claimedToday ? 'checkin-button--done' : ''}}" loading="{{checking}}" disabled="{{checkin.claimedToday || checking}}" bindtap="checkin">{{checkin.claimedToday ? '今日已签到' : '领取积分'}}</button>
  </view>

  <view class="section-title">
    <view class="section-title__main">补充灵感积分</view>
    <view class="section-title__sub">支付后即时到账</view>
  </view>

  <view class="package-grid">
    <button
      wx:for="{{packages}}"
      wx:key="id"
      class="package-card {{selectedId === item.id ? 'package-card--selected' : ''}}"
      data-id="{{item.id}}"
      bindtap="selectPackage"
    >
      <view wx:if="{{item.badge}}" class="package-badge">{{item.badge}}</view>
      <view class="package-credits">{{item.totalCredits}}<text> 积分</text></view>
      <view class="package-price"><text>¥</text>{{item.priceYuan}}</view>
      <view wx:if="{{item.bonus}}" class="package-bonus">含赠送 {{item.bonus}} 积分</view>
    </button>
  </view>

  <button class="primary-button pay-button" loading="{{paying}}" disabled="{{!selectedId || paying}}" bindtap="pay">微信支付</button>
  <view class="pay-note">充值积分仅用于本小程序内的图片生成服务</view>

  <view class="section-title transaction-title">
    <view class="section-title__main">积分明细</view>
  </view>
  <view class="transaction-list">
    <view wx:for="{{transactions}}" wx:key="id" class="transaction-row">
      <view>
        <view class="transaction-name">{{item.title}}</view>
        <view class="transaction-time">{{item.displayTime}}</view>
      </view>
      <view class="transaction-amount {{item.amount > 0 ? 'transaction-amount--plus' : ''}}">{{item.amount > 0 ? '+' : ''}}{{item.amount}}</view>
    </view>
    <view wx:if="{{!transactions.length}}" class="empty">暂无积分记录</view>
  </view>
</view>

<view class="page profile-page page-enter" style="padding-top: {{navSpacer}}rpx">
  <custom-nav credits="{{user ? user.credits : null}}"></custom-nav>

  <view wx:if="{{!user}}" class="guest-panel">
    <view class="guest-title">登录后管理个人主页</view>
    <view class="guest-sub">游客可浏览模板；签到、创作与作品需要登录。登录后可一键授权微信头像与昵称。</view>
    <button class="primary-button guest-login" bindtap="doLogin">微信快捷登录</button>
  </view>

  <block wx:else>
    <view class="profile-head">
      <button class="avatar-button" open-type="chooseAvatar" bindchooseavatar="chooseAvatar" hover-class="avatar-button--hover">
        <view class="avatar-face">
          <image wx:if="{{avatarUrl}}" class="avatar-image" src="{{avatarUrl}}" mode="aspectFill"></image>
          <view wx:else class="avatar-fallback">
            <text class="avatar-initial">{{avatarInitial}}</text>
          </view>
        </view>
        <view class="avatar-edit">{{avatarUrl ? '改' : '授权'}}</view>
      </button>
      <view class="profile-copy">
        <view class="profile-kicker">MY XIANGHUI</view>
        <input
          class="nickname-input"
          type="nickname"
          value="{{nickname}}"
          placeholder="点此使用微信昵称"
          bindinput="nicknameInput"
          bindblur="nicknameBlur"
          bindnicknamereview="nicknameReview"
        />
        <view class="profile-id">花漾相绘用户 · {{user.maskedId}}</view>
      </view>
    </view>

    <view wx:if="{{!profileComplete}}" class="profile-setup">
      <view class="profile-setup__title">完善微信资料（约 10 秒）</view>
      <view class="profile-setup__text">
        微信政策要求：头像与昵称需你主动授权，无法在登录时静默读取。请按下面两步完成，完成后会自动显示在个人主页。
      </view>
      <view class="profile-setup__steps">
        <view class="profile-setup__step">
          <text class="profile-setup__num">1</text>
          <text>点左侧圆形头像 → 选择「用微信头像」</text>
        </view>
        <view class="profile-setup__step">
          <text class="profile-setup__num">2</text>
          <text>点昵称输入框 → 选择微信昵称并确认</text>
        </view>
      </view>
      <button class="primary-button profile-setup__btn" open-type="chooseAvatar" bindchooseavatar="chooseAvatar">
        立即授权微信头像
      </button>
    </view>

    <view class="stats-grid">
      <view><text class="stats-value">{{user.credits}}</text><text>可用积分</text></view>
      <view><text class="stats-value">{{stats.completedJobs}}</text><text>完成创作</text></view>
      <view><text class="stats-value">{{stats.generatedImages}}</text><text>生成作品</text></view>
    </view>

    <view class="menu-list">
      <button bindtap="openHelp"><view class="menu-label"><view class="menu-icon menu-icon--help">?</view><text>使用帮助</text></view><text class="menu-arrow">›</text></button>
      <button bindtap="openPrivacy"><view class="menu-label"><view class="menu-icon menu-icon--privacy">i</view><text>用户隐私说明</text></view><text class="menu-arrow">›</text></button>
      <button bindtap="openUserAgreement"><view class="menu-label"><view class="menu-icon menu-icon--agree">约</view><text>用户服务协议</text></view><text class="menu-arrow">›</text></button>
    </view>

    <view class="account-note">
      <view class="account-note__title">微信快捷登录已开启</view>
      <view>账号与积分绑定当前微信。头像、昵称仅在你授权后写入资料；你可随时在本页修改。</view>
    </view>
  </block>
</view>

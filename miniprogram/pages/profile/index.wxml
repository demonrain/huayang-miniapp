<view class="page profile-page page-enter" style="padding-top: {{navSpacer}}rpx">
  <custom-nav credits="{{user ? user.credits : null}}"></custom-nav>

  <view wx:if="{{!user}}" class="guest-panel">
    <view class="guest-title">欢迎来到花漾相绘</view>
    <view class="guest-sub">点击登录将授权微信登录，并尽量自动填入头像与昵称（需你在弹窗中允许；若未能自动获取，登录后点头像/昵称可一键授权）。</view>
    <button class="primary-button guest-login" bindtap="doLogin">微信快捷登录</button>
  </view>

  <block wx:else>
    <view class="profile-head">
      <!-- Match POC .profile-avatar: relative wrap, face + corner camera badge as siblings -->
      <view class="profile-avatar">
        <button class="avatar-button" open-type="chooseAvatar" bindchooseavatar="chooseAvatar" hover-class="avatar-button--hover">
          <view class="avatar-face">
            <image wx:if="{{avatarUrl}}" class="avatar-image" src="{{avatarUrl}}" mode="aspectFill"></image>
            <view wx:else class="avatar-fallback">
              <text class="avatar-initial">{{avatarInitial}}</text>
            </view>
          </view>
        </button>
        <view class="avatar-camera" catchtap="noop">
          <image class="avatar-camera__icon" src="/assets/icons/camera.png" mode="aspectFit"></image>
        </view>
      </view>
      <view class="profile-copy">
        <input
          class="nickname-input"
          type="nickname"
          value="{{nickname}}"
          placeholder="点击填写微信昵称"
          bindinput="nicknameInput"
          bindblur="nicknameBlur"
          bindnicknamereview="nicknameReview"
        />
        <view class="profile-hint">点击头像换微信头像 · 点击昵称可修改</view>
        <view class="profile-id">花漾相绘用户 · {{user.maskedId}}</view>
      </view>
    </view>

    <view class="bio-card">
      <view class="bio-card__head">
        <text class="bio-card__title">个人简介</text>
        <text class="bio-card__count">{{bio.length}}/80</text>
      </view>
      <textarea
        class="bio-input"
        value="{{bio}}"
        maxlength="80"
        placeholder="写一句属于你的花漾心情～"
        auto-height
        bindinput="bioInput"
        bindblur="bioBlur"
      ></textarea>
    </view>

    <view wx:if="{{!profileComplete}}" class="profile-setup">
      <view class="profile-setup__title">完善微信资料</view>
      <view class="profile-setup__text">微信规定头像/昵称需你主动授权：点上方头像选择微信头像，点昵称栏使用微信昵称。完成后资料会自动保存。</view>
    </view>

    <view class="stats-grid stats-grid--4">
      <view class="stats-cell">
        <text class="stats-value">{{user.credits}}</text>
        <text class="stats-label">可用积分</text>
      </view>
      <view class="stats-cell">
        <text class="stats-value">{{stats.completedJobs}}</text>
        <text class="stats-label">完成创作</text>
      </view>
      <view class="stats-cell">
        <text class="stats-value">{{stats.generatedImages}}</text>
        <text class="stats-label">生成作品</text>
      </view>
      <view class="stats-cell stats-cell--flower">
        <view class="stats-flower">
          <image class="stats-flower__icon" src="/assets/icons/flower-gift-active.png" mode="aspectFit"></image>
          <text class="stats-value">{{stats.flowersReceived || user.flowersReceived || 0}}</text>
        </view>
        <text class="stats-label">收到的花</text>
      </view>
    </view>

    <view class="checkin-row">
      <view class="checkin-copy">
        <view class="checkin-title">{{checkinTitle}}</view>
        <view class="checkin-sub">{{checkinSub}}</view>
      </view>
      <button
        class="checkin-button {{checkinDone ? 'checkin-button--done' : ''}}"
        hover-class="none"
        loading="{{checking}}"
        disabled="{{!checkinReady || checkinDone || checking}}"
        bindtap="doCheckin"
      >{{checkinBtnText}}</button>
    </view>

    <view class="section-block">
      <view class="section-block__main">我的花园</view>
      <view class="section-block__sub">作品与账号管理</view>
    </view>

    <view class="menu-list">
      <button bindtap="goWorks" hover-class="menu-item--hover">
        <view class="menu-label">
          <view class="menu-icon menu-icon--works">
            <image class="menu-icon__img" src="/assets/icons/menu-works.svg" mode="aspectFit"></image>
          </view>
          <text>我的作品</text>
        </view>
        <text class="menu-arrow">›</text>
      </button>
      <button bindtap="goRedeem" hover-class="menu-item--hover">
        <view class="menu-label">
          <view class="menu-icon menu-icon--redeem">
            <image class="menu-icon__img" src="/assets/icons/menu-redeem.svg" mode="aspectFit"></image>
          </view>
          <text>积分兑换</text>
        </view>
        <text class="menu-arrow">›</text>
      </button>
      <button bindtap="goFeedback" hover-class="menu-item--hover">
        <view class="menu-label">
          <view class="menu-icon menu-icon--feedback">
            <image class="menu-icon__img" src="/assets/icons/menu-feedback.svg" mode="aspectFit"></image>
          </view>
          <text>建议反馈</text>
        </view>
        <text class="menu-arrow">›</text>
      </button>
      <button bindtap="openHelp" hover-class="menu-item--hover">
        <view class="menu-label">
          <view class="menu-icon menu-icon--help">
            <image class="menu-icon__img" src="/assets/icons/menu-help.svg" mode="aspectFit"></image>
          </view>
          <text>使用帮助 / 新手练习</text>
        </view>
        <text class="menu-arrow">›</text>
      </button>
      <button bindtap="openPrivacy" hover-class="menu-item--hover">
        <view class="menu-label">
          <view class="menu-icon menu-icon--privacy">
            <image class="menu-icon__img" src="/assets/icons/menu-privacy.svg" mode="aspectFit"></image>
          </view>
          <text>隐私与安全</text>
        </view>
        <text class="menu-arrow">›</text>
      </button>
      <button bindtap="openUserAgreement" hover-class="menu-item--hover">
        <view class="menu-label">
          <view class="menu-icon menu-icon--agree">
            <image class="menu-icon__img" src="/assets/icons/menu-agreement.svg" mode="aspectFit"></image>
          </view>
          <text>用户服务协议</text>
        </view>
        <text class="menu-arrow">›</text>
      </button>
    </view>
  </block>
</view>

/* —— Guest —— */
.guest-panel {
  margin-top: 24rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
  box-shadow: 0 10rpx 28rpx rgba(108, 81, 92, 0.06);
}

.guest-title {
  font-size: 32rpx;
  font-weight: 650;
}

.guest-sub {
  margin: 14rpx 0 32rpx;
  color: var(--muted);
  font-size: 22rpx;
  line-height: 1.6;
}

.guest-login {
  width: 280rpx;
  margin: 0 auto;
}

/* —— Head (POC-like flat strip, miniapp palette) —— */
.profile-head {
  margin-top: 8rpx;
  padding: 28rpx 8rpx 26rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
  border-bottom: 2rpx solid var(--line);
}

/* POC: .profile-avatar { position: relative; width/height fixed } */
.profile-avatar {
  position: relative;
  width: 144rpx;
  height: 144rpx;
  flex: none;
  overflow: visible;
}

.avatar-button {
  position: absolute;
  left: 0;
  top: 0;
  width: 144rpx;
  height: 144rpx;
  margin: 0;
  padding: 0;
  display: block;
  overflow: visible;
  background: transparent;
  border: 0;
  border-radius: 50%;
  box-shadow: none;
  font-weight: 400;
  line-height: 1;
}

.avatar-button::after {
  border: 0;
}

.avatar-button--hover {
  opacity: 0.88;
}

.avatar-face {
  width: 144rpx;
  height: 144rpx;
  overflow: hidden;
  background: #fff;
  border: 6rpx solid #fff;
  border-radius: 50%;
  box-shadow: 0 10rpx 28rpx rgba(100, 76, 85, 0.12);
  box-sizing: border-box;
}

.avatar-image {
  display: block;
  width: 100%;
  height: 100%;
}

.avatar-fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #ffe8ec 0%, #fff6e8 48%, #e8f7f2 100%);
}

.avatar-initial {
  color: var(--coral);
  font-family: "Kaiti SC", "STKaiti", "Songti SC", serif;
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1;
}

/* POC: .profile-avatar span { position: absolute; right: -1px; bottom: 1px; ... } */
.avatar-camera {
  position: absolute;
  right: -2rpx;
  bottom: 2rpx;
  z-index: 5;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  background: var(--mint);
  border: 6rpx solid var(--paper);
  border-radius: 50%;
  box-shadow: 0 6rpx 14rpx rgba(88, 173, 153, 0.32);
  box-sizing: border-box;
}

.avatar-camera__icon {
  width: 24rpx;
  height: 24rpx;
  display: block;
}

.profile-copy {
  min-width: 0;
  flex: 1;
}

.nickname-input {
  width: 100%;
  height: 64rpx;
  margin: 0;
  padding: 0;
  color: var(--ink);
  font-family: "Kaiti SC", "STKaiti", "Songti SC", serif;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 64rpx;
}

.profile-hint {
  margin-top: 8rpx;
  color: var(--green);
  font-size: 20rpx;
  line-height: 1.35;
}

.profile-id {
  margin-top: 6rpx;
  color: var(--muted);
  font-size: 20rpx;
}

/* —— Setup tip —— */
.profile-setup {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  background: linear-gradient(180deg, #fff8e7 0%, #fffdf8 100%);
  border: 2rpx solid #f3ead1;
  border-radius: 14rpx;
}

.profile-setup__title {
  color: #9b7b3f;
  font-size: 24rpx;
  font-weight: 700;
}

.profile-setup__text {
  margin-top: 8rpx;
  color: #84775c;
  font-size: 20rpx;
  line-height: 1.55;
}

/* —— Stats —— */
.stats-grid {
  margin-top: 0;
  padding: 28rpx 12rpx;
  display: flex;
  border-bottom: 2rpx solid var(--line);
  background: transparent;
}

.stats-cell {
  min-width: 0;
  flex: 1;
  text-align: center;
  border-right: 2rpx solid var(--line);
}

.stats-cell:last-child {
  border-right: 0;
}

.stats-value {
  display: block;
  color: var(--coral);
  font-family: Georgia, serif;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.15;
}

.stats-label {
  display: block;
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 18rpx;
}

/* —— Check-in (from wallet, POC-like row) —— */
.checkin-row {
  margin-top: 8rpx;
  padding: 22rpx 4rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  border-bottom: 2rpx solid var(--line);
}

.checkin-copy {
  min-width: 0;
  flex: 1;
}

.checkin-title {
  font-size: 28rpx;
  font-weight: 650;
  color: var(--ink);
}

.checkin-sub {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 20rpx;
  line-height: 1.4;
}

.checkin-button {
  width: auto;
  min-width: 148rpx;
  height: 68rpx;
  flex: none;
  margin: 0;
  padding: 0 22rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  background: var(--yellow);
  border: 0;
  border-radius: 12rpx;
  color: #6c5925;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
  white-space: nowrap;
}

.checkin-button::after {
  border: 0;
}

.checkin-button--done,
.checkin-button[disabled] {
  background-color: #edf1ef !important;
  color: #8a918e !important;
  opacity: 1 !important;
}

/* —— Section —— */
.section-block {
  margin-top: 28rpx;
  padding: 0 4rpx 12rpx;
}

.section-block__main {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--ink);
}

.section-block__sub {
  margin-top: 6rpx;
  color: var(--muted);
  font-size: 20rpx;
}

/* —— Menu —— */
.menu-list {
  margin-top: 4rpx;
  overflow: hidden;
  background: transparent;
}

.menu-list button {
  width: 100%;
  min-height: 96rpx;
  height: auto;
  margin: 0;
  padding: 24rpx 4rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: transparent;
  border: 0;
  border-bottom: 2rpx solid var(--line);
  border-radius: 0;
  color: var(--ink);
  font-size: 28rpx;
  font-weight: 400;
  line-height: 1.3;
}

.menu-list button::after {
  border: 0;
}

.menu-list button:last-child {
  border-bottom: 0;
}

.menu-item--hover {
  opacity: 0.72;
}

.menu-label {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.menu-icon {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-family: Georgia, "PingFang SC", serif;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 44rpx;
}

.menu-icon--works {
  background: var(--mint-soft);
  color: var(--green);
}

.menu-icon--feedback {
  background: #fff6e8;
  color: #c48a3a;
}

.menu-icon--redeem {
  background: #fff6e0;
  color: #b08a2e;
}

.menu-icon--help {
  background: var(--pink-soft);
  color: var(--coral);
}

.menu-icon--privacy {
  background: #eef6f3;
  color: #4a8f7c;
}

.menu-icon--agree {
  background: #f3eef8;
  color: var(--lavender);
}

.menu-arrow {
  color: #c5b7bc;
  font-size: 36rpx;
  font-weight: 300;
  line-height: 1;
}

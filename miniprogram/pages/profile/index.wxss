.profile-setup {
  margin-top: 18rpx;
  padding: 24rpx 22rpx;
  background: linear-gradient(180deg, #fff8e7 0%, #fffdf8 100%);
  border: 2rpx solid #f3ead1;
  border-radius: 16rpx;
}

.profile-setup__title {
  color: #9b7b3f;
  font-size: 28rpx;
  font-weight: 700;
}

.profile-setup__text {
  margin-top: 10rpx;
  color: #84775c;
  font-size: 22rpx;
  line-height: 1.6;
}

.profile-setup__steps {
  margin: 18rpx 0 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.profile-setup__step {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  color: #6f6550;
  font-size: 22rpx;
  line-height: 1.5;
}

.profile-setup__num {
  width: 36rpx;
  height: 36rpx;
  flex: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 50%;
  color: var(--coral);
  font-weight: 700;
  font-size: 20rpx;
  line-height: 36rpx;
  text-align: center;
}

.profile-setup__btn {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
}

.guest-panel {
  margin-top: 24rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
  box-shadow: 0 10rpx 28rpx rgba(108, 81, 92, 0.06);
}

.guest-title {
  font-size: 32rpx;
  font-weight: 650;
}

.guest-sub {
  margin: 14rpx 0 32rpx;
  color: var(--muted);
  font-size: 22rpx;
  line-height: 1.6;
}

.guest-login {
  width: 280rpx;
  margin: 0 auto;
}

.profile-head {
  min-height: 170rpx;
  padding: 22rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: linear-gradient(135deg, var(--mint-soft), #fff5f6);
  border: 2rpx solid #e5eee9;
  border-radius: 16rpx;
}

.avatar-button {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  min-width: 120rpx;
  min-height: 120rpx;
  flex: none;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: visible;
  background: transparent;
  border: 0;
  border-radius: 0;
  box-shadow: none;
  font-weight: 400;
  line-height: 1;
}

.avatar-button::after {
  border: 0;
}

.avatar-button--hover {
  opacity: 0.88;
}

.avatar-face {
  width: 120rpx;
  height: 120rpx;
  overflow: hidden;
  background: #fff;
  border: 4rpx solid #fff;
  border-radius: 50%;
  box-shadow: 0 8rpx 22rpx rgba(100, 76, 85, 0.12);
  box-sizing: border-box;
}

.avatar-image {
  display: block;
  width: 100%;
  height: 100%;
}

.avatar-fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #ffe8ec 0%, #fff6e8 48%, #e8f7f2 100%);
}

.avatar-initial {
  color: var(--coral);
  font-family: "Kaiti SC", "STKaiti", "Songti SC", serif;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1;
}

.avatar-edit {
  position: absolute;
  right: -2rpx;
  bottom: -2rpx;
  z-index: 2;
  width: 38rpx;
  height: 38rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--mint);
  border: 4rpx solid #fff9f8;
  border-radius: 50%;
  color: #fff;
  font-size: 16rpx;
  font-weight: 700;
  line-height: 1;
  box-shadow: 0 4rpx 10rpx rgba(88, 173, 153, 0.28);
}

.profile-copy { min-width: 0; flex: 1; }
.profile-kicker { color: var(--green); font-family: Georgia, serif; font-size: 15rpx; }
.nickname-input { width: 100%; height: 58rpx; margin-top: 2rpx; font-size: 35rpx; font-weight: 650; }
.profile-id { margin-top: 5rpx; color: var(--muted); font-size: 20rpx; }

.stats-grid {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  overflow: hidden;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(108,82,92,0.05);
}

.stats-grid view { min-width: 0; padding: 28rpx 8rpx; text-align: center; border-right: 2rpx solid var(--line); }
.stats-grid view:last-child { border-right: 0; }
.stats-value { display: block; color: var(--coral); font-family: Georgia, serif; font-size: 35rpx; font-weight: 700; }
.stats-grid text { display: block; margin-top: 5rpx; color: var(--muted); font-size: 18rpx; }

.menu-list { margin-top: 34rpx; overflow: hidden; background: #fff; border: 2rpx solid var(--line); border-radius: 16rpx; box-shadow: 0 8rpx 24rpx rgba(108,82,92,0.04); }
.menu-list button { width: 100%; height: 104rpx; margin: 0; padding: 0 24rpx; display: flex; align-items: center; justify-content: space-between; background: transparent; border-bottom: 2rpx solid var(--line); color: var(--ink); font-size: 25rpx; font-weight: 400; line-height: 104rpx; }
.menu-list button:last-child { border-bottom: 0; }
.menu-label { display: flex; align-items: center; gap: 16rpx; }
.menu-icon { width: 44rpx; height: 44rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; font-family: Georgia, serif; font-size: 22rpx; font-weight: 700; line-height: 44rpx; }
.menu-icon--help { background: var(--pink-soft); color: var(--coral); }
.menu-icon--privacy { background: var(--mint-soft); color: var(--green); }
.menu-icon--agree { background: #f3eef8; color: var(--lavender); }
.menu-arrow { color: #c5b7bc; font-size: 36rpx; font-weight: 300; }

.account-note { margin-top: 24rpx; padding: 22rpx; background: #fff8e7; border: 2rpx solid #f3ead1; border-radius: 14rpx; color: #84775c; font-size: 20rpx; line-height: 1.65; }
.account-note__title { color: #9b7b3f; font-size: 23rpx; font-weight: 650; }

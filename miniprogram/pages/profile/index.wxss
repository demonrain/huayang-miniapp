.profile-head {
  min-height: 156rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-button {
  width: 120rpx;
  height: 120rpx;
  flex: none;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: var(--yellow);
  color: var(--ink);
  font-family: "Songti SC", serif;
  font-size: 52rpx;
  line-height: 120rpx;
}

.avatar-button image { width: 100%; height: 100%; }
.profile-copy { min-width: 0; flex: 1; }
.nickname-input { width: 100%; height: 60rpx; font-size: 38rpx; font-weight: 700; }
.profile-id { margin-top: 7rpx; color: var(--muted); font-size: 21rpx; }

.stats-grid {
  margin-top: 30rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  background: var(--surface);
  border: 2rpx solid var(--line);
}

.stats-grid view { min-width: 0; padding: 27rpx 8rpx; text-align: center; border-right: 2rpx solid var(--line); }
.stats-grid view:last-child { border-right: 0; }
.stats-value { display: block; font-family: Georgia, serif; font-size: 36rpx; font-weight: 700; }
.stats-grid text { display: block; margin-top: 5rpx; color: var(--muted); font-size: 19rpx; }

.menu-list { margin-top: 38rpx; background: var(--surface); border: 2rpx solid var(--line); }
.menu-list button { width: 100%; height: 100rpx; margin: 0; padding: 0 24rpx; display: flex; align-items: center; justify-content: space-between; background: transparent; border-bottom: 2rpx solid var(--line); color: var(--ink); font-size: 26rpx; font-weight: 400; line-height: 100rpx; }
.menu-list button:last-child { border-bottom: 0; }
.menu-arrow { color: #999a95; font-size: 38rpx; font-weight: 300; }

.account-note { margin-top: 26rpx; padding: 22rpx; background: #e7eee9; color: #5c6862; font-size: 21rpx; line-height: 1.6; }
.account-note__title { color: var(--green); font-size: 24rpx; font-weight: 700; }

.feedback-page {
  padding-bottom: calc(env(safe-area-inset-bottom) + 48rpx);
}

.fb-hero {
  margin-top: 8rpx;
  padding: 8rpx 4rpx 16rpx;
}

.fb-kicker {
  color: var(--coral);
  font-family: Georgia, serif;
  font-size: 17rpx;
  letter-spacing: 2rpx;
}

.fb-title {
  margin-top: 8rpx;
  font-size: 40rpx;
  font-weight: 700;
}

.fb-sub {
  margin-top: 10rpx;
  color: var(--muted);
  font-size: 22rpx;
  line-height: 1.55;
}

.section-label {
  margin: 12rpx 0 12rpx;
  color: var(--muted);
  font-size: 22rpx;
  font-weight: 600;
}

.type-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.type-card {
  padding: 20rpx 22rpx;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: 14rpx;
  box-shadow: 0 6rpx 16rpx rgba(108, 82, 92, 0.04);
}

.type-card.is-selected {
  border-color: #f2a4b1;
  background: #fffafb;
  box-shadow: 0 8rpx 20rpx rgba(231, 109, 130, 0.1);
}

.type-card__name {
  font-size: 28rpx;
  font-weight: 650;
}

.type-card__desc {
  margin-top: 6rpx;
  color: var(--muted);
  font-size: 22rpx;
  line-height: 1.4;
}

.fb-card {
  position: relative;
  padding: 18rpx 20rpx 40rpx;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: 14rpx;
}

.fb-textarea {
  width: 100%;
  min-height: 220rpx;
  color: var(--ink);
  font-size: 26rpx;
  line-height: 1.55;
}

.fb-count {
  position: absolute;
  right: 18rpx;
  bottom: 12rpx;
  color: var(--muted);
  font-size: 20rpx;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.photo-cell {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f4eaec;
}

.photo-cell image {
  width: 100%;
  height: 100%;
}

.photo-remove {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(48, 40, 44, 0.55);
  border-radius: 50%;
  color: #fff;
  font-size: 24rpx;
}

.photo-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  border: 2rpx dashed #e0c8cc;
  background: #fff;
  color: var(--muted);
  font-size: 20rpx;
}

.photo-add__plus {
  font-size: 36rpx;
  line-height: 1;
  color: var(--coral);
}

.fb-submit {
  margin-top: 36rpx;
  width: 100%;
}

/* Tabs */
.fb-tabs {
  display: flex;
  gap: 12rpx;
  margin: 8rpx 0 20rpx;
  padding: 8rpx;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: 14rpx;
}

.fb-tab {
  flex: 1;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  color: var(--muted);
  font-size: 26rpx;
  font-weight: 600;
}

.fb-tab.is-active {
  background: var(--pink-soft);
  color: var(--coral);
}

/* History */
.history-loading,
.history-empty {
  padding: 64rpx 24rpx;
  text-align: center;
  color: var(--muted);
  font-size: 24rpx;
}

.history-empty__title {
  color: var(--ink);
  font-size: 30rpx;
  font-weight: 650;
}

.history-empty__sub {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.5;
}

.history-empty__btn {
  margin: 28rpx auto 0;
  width: 280rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-card {
  padding: 22rpx 22rpx 20rpx;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
  box-shadow: 0 8rpx 22rpx rgba(108, 82, 92, 0.05);
}

.history-card__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.history-card__type {
  font-size: 28rpx;
  font-weight: 650;
  color: var(--ink);
}

.history-card__status {
  flex: none;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.history-card__status.is-pending {
  background: #fff6e8;
  color: #c48a3a;
}

.history-card__status.is-replied {
  background: var(--mint-soft);
  color: var(--green);
}

.history-card__time {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 20rpx;
}

.history-card__content {
  margin-top: 14rpx;
  color: var(--ink);
  font-size: 26rpx;
  line-height: 1.55;
  white-space: pre-wrap;
  word-break: break-word;
}

.history-images {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.history-thumb {
  width: 140rpx;
  height: 140rpx;
  border-radius: 10rpx;
  background: #f4eaec;
}

.history-reply {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  background: linear-gradient(165deg, #f7fbf9 0%, #eef8f4 100%);
  border: 2rpx solid #d8eee7;
  border-radius: 12rpx;
}

.history-reply__label {
  color: var(--green);
  font-size: 20rpx;
  font-weight: 650;
}

.history-reply__text {
  margin-top: 8rpx;
  color: #44665e;
  font-size: 24rpx;
  line-height: 1.55;
  white-space: pre-wrap;
  word-break: break-word;
}

.history-wait {
  margin-top: 14rpx;
  color: var(--muted);
  font-size: 22rpx;
  line-height: 1.45;
}

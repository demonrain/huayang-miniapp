<view class="page feedback-page page-enter" style="padding-top: {{navSpacer}}rpx">
  <custom-nav show-back title="建议反馈" credits="{{credits}}"></custom-nav>

  <view class="fb-hero">
    <view class="fb-kicker">FEEDBACK</view>
    <view class="fb-title">建议与反馈</view>
    <view class="fb-sub">告诉我们你的想法，帮花漾相绘开得更好</view>
  </view>

  <view class="section-label">反馈类型</view>
  <view class="type-list">
    <view
      wx:for="{{types}}"
      wx:key="id"
      class="type-card {{type === item.id ? 'is-selected' : ''}}"
      data-id="{{item.id}}"
      bindtap="selectType"
    >
      <view class="type-card__name">{{item.name}}</view>
      <view class="type-card__desc">{{item.desc}}</view>
    </view>
  </view>

  <view class="section-label">详细说明</view>
  <view class="fb-card">
    <textarea
      class="fb-textarea"
      maxlength="800"
      placeholder="请描述你遇到的问题、期望的功能，或想要的风格效果…"
      value="{{content}}"
      bindinput="onContentInput"
      show-confirm-bar="{{false}}"
    ></textarea>
    <view class="fb-count">{{content.length}}/800</view>
  </view>

  <block wx:if="{{type === 'template_request' || files.length}}">
    <view class="section-label">{{type === 'template_request' ? '参考图片（可选，最多 6 张）' : '附图（可选）'}}</view>
    <view class="photo-grid">
      <view wx:for="{{files}}" wx:key="path" class="photo-cell">
        <image src="{{item.path}}" mode="aspectFill" data-path="{{item.path}}" bindtap="previewImage"></image>
        <view class="photo-remove" data-index="{{index}}" catchtap="removeImage">×</view>
      </view>
      <view wx:if="{{files.length < maxFiles}}" class="photo-cell photo-add" bindtap="chooseImages">
        <view class="photo-add__plus">＋</view>
        <text>添加</text>
      </view>
    </view>
  </block>

  <button
    class="primary-button fb-submit"
    loading="{{submitting}}"
    disabled="{{submitting}}"
    bindtap="submit"
  >提交反馈</button>
</view>

<view class="page job-page page-enter {{showcase && !demo ? 'job-page--showcase' : ''}}" style="padding-top: {{navSpacer}}rpx">
  <custom-nav show-back credits="{{credits}}"></custom-nav>

  <block wx:if="{{job}}">
    <view wx:if="{{demo}}" class="demo-banner">练习模式 · 真实进度界面 · 演示出图不扣积分、不写入作品库</view>
    <view wx:elif="{{showcase}}" class="demo-banner">花海作品 · 点击图片可查看大图 · 去创作同款风格</view>
    <view class="job-meta {{showcase ? 'job-meta--showcase' : ''}}">
      <view><text>风格</text><text class="job-meta__value">{{job.templateName}}</text></view>
      <view wx:if="{{!showcase}}"><text>数量</text><text class="job-meta__value">{{job.assetIds.length}} 张</text></view>
      <view wx:if="{{!showcase}}"><text>消耗</text><text class="job-meta__value">{{demo ? '0（演示）' : (job.cost + ' 积分')}}</text></view>
      <view wx:else><text>作者</text><text class="job-meta__value">{{authorNickname || '花漾用户'}}</text></view>
      <view wx:if="{{showcase}}"><text>效果</text><text class="job-meta__value">{{job.results.length}} 张</text></view>
    </view>

    <view wx:if="{{isWaiting}}" class="generating">
      <view class="progress-flower">
        <view class="progress-petal progress-petal--1"></view>
        <view class="progress-petal progress-petal--2"></view>
        <view class="progress-petal progress-petal--3"></view>
        <view class="progress-petal progress-petal--4"></view>
        <view class="progress-dot"></view>
      </view>
      <view class="generating-title">正在让照片开花</view>
      <view class="generating-status">{{statusText}} · {{demo ? '演示约数秒' : etaStatus}}</view>
      <view class="generating-tip">{{waitingTip}}</view>
      <view class="progress-track">
        <view class="progress-track__bar"></view>
      </view>
      <view class="generating-note">
        <block wx:if="{{demo}}">练习加速演示排队与出图过程。真实创作按每张 2–5 分钟估算，完成后可在「作品」查看，也可开启微信提醒。</block>
        <block wx:else>{{etaNote}}</block>
      </view>
    </view>

    <!-- Friendly failed state: no raw error dump -->
    <view wx:elif="{{job.status === 'failed'}}" class="fail-card">
      <view class="fail-illus">
        <view class="fail-flower">
          <view class="fail-petal fail-petal--1"></view>
          <view class="fail-petal fail-petal--2"></view>
          <view class="fail-petal fail-petal--3"></view>
          <view class="fail-petal fail-petal--4"></view>
          <view class="fail-dot"></view>
        </view>
        <view class="fail-cloud"></view>
      </view>
      <view class="fail-title">哎呀，小花瓣没开好</view>
      <view class="fail-desc">{{failMessage}}</view>
      <view class="fail-refund">本次消耗的积分已自动退回账户～</view>
      <view wx:if="{{serviceUnstable}}" class="fail-unstable">
        最近几次生成都不太顺利，服务可能暂时不稳定。建议稍后再试，或先去逛逛别的风格。
      </view>
    </view>

    <view wx:if="{{job.status === 'succeeded'}}">
      <view class="section-title">
        <view class="section-title__main">{{demo ? '演示作品' : (showcase ? '精选效果' : '你的作品')}}</view>
        <view class="section-title__sub">{{job.results.length}} 张已完成 · {{demo ? '效果图为风格封面演示' : '点击查看大图'}}</view>
      </view>
      <view class="result-list">
        <view wx:for="{{job.results}}" wx:key="id" class="result-item">
          <image
            src="{{item.thumbUrl || item.url}}"
            mode="widthFix"
            data-url="{{item.url}}"
            lazy-load
            bindtap="preview"
          ></image>
          <view class="result-number">{{index + 1}} / {{job.results.length}}</view>
        </view>
      </view>

      <view wx:if="{{job.originals.length}}" class="original-section">
        <view class="section-title original-section__title">
          <view class="section-title__main">原图对照</view>
          <view class="section-title__sub">{{showcase ? '作者已授权展示原图' : '点击查看原图大图'}}</view>
        </view>
        <scroll-view class="original-scroll" scroll-x enhanced show-scrollbar="false">
          <view class="original-row">
            <view
              wx:for="{{job.originals}}"
              wx:key="id"
              class="original-card"
              data-url="{{item.url}}"
              bindtap="previewOriginal"
            >
              <image class="original-card__image" src="{{item.thumbUrl || item.url}}" mode="aspectFill" lazy-load></image>
              <view class="original-card__label">原图 {{item.index}}</view>
            </view>
          </view>
        </scroll-view>
      </view>

      <!-- Owner: share to 花海 — switch auto-saves -->
      <view wx:if="{{!demo && !showcase && isOwner && job.status === 'succeeded'}}" class="public-share-panel">
        <view class="public-share-panel__title">分享到花海</view>
        <view class="public-share-panel__desc">开启后作品会出现在「花海」，其他用户可浏览与点赞；同一作品分享奖励仅能获得一次。切换开关后自动保存。</view>
        <view wx:if="{{galleryPublishCredits > 0 || galleryLikeAuthorCredits > 0}}" class="public-share-reward-tip">
          首次分享可获 {{galleryPublishCredits}} 积分
          <text wx:if="{{galleryLikeAuthorCredits > 0}}">；被点赞你得 {{galleryLikeAuthorCredits}} 积分，点赞者得 {{galleryLikeLikerCredits}} 积分</text>
        </view>
        <label class="public-share-row">
          <text>分享到花海</text>
          <switch checked="{{publicShareEnabled}}" color="#E76D82" disabled="{{publicShareSaving}}" bindchange="onPublicShareToggle" />
        </label>
        <label class="public-share-row {{publicShareEnabled ? '' : 'is-disabled'}}">
          <text>同时显示原图</text>
          <switch checked="{{publicShareShowOriginals}}" disabled="{{!publicShareEnabled || publicShareSaving}}" color="#E76D82" bindchange="onPublicShareOriginalsToggle" />
        </label>
        <view class="public-share-panel__note">{{publicShareEnabled ? (publicShareShowOriginals ? '访客可看生成图与原图' : '访客仅可看生成效果，不看原图') : '当前未分享，他人无法在花海中看到'}}</view>
      </view>

      <!-- Make avatar: open crop preview -->
      <view wx:if="{{!demo && !showcase && job.status === 'succeeded' && job.results.length}}" class="avatar-panel">
        <view class="avatar-panel__title">一键制作头像</view>
        <view class="avatar-panel__desc">进入预览界面，拖动/缩放作品，裁成方形或圆形后保存到相册</view>
        <button class="primary-button avatar-make-btn" data-index="0" bindtap="openAvatarCrop">制作头像</button>
        <view wx:if="{{job.results.length > 1}}" class="avatar-multi">
          <text class="avatar-multi__label">从第几张制作：</text>
          <view class="avatar-multi__list">
            <view
              wx:for="{{job.results}}"
              wx:key="id"
              class="avatar-multi__item"
              data-index="{{index}}"
              bindtap="openAvatarCrop"
            >图{{index + 1}}</view>
          </view>
        </view>
      </view>

      <!-- Showcase: more works from same author -->
      <view wx:if="{{showcase && authorWorks.length}}" class="author-works">
        <view class="section-title">
          <view class="section-title__main">TA 的其他分享</view>
          <view class="section-title__sub">{{authorNickname || '作者'}} 在花海里的更多作品</view>
        </view>
        <scroll-view class="author-works__scroll" scroll-x enhanced show-scrollbar="false">
          <view class="author-works__row">
            <view
              wx:for="{{authorWorks}}"
              wx:key="id"
              class="author-works__card"
              data-id="{{item.id}}"
              bindtap="openAuthorWork"
            >
              <image wx:if="{{item.coverUrl}}" class="author-works__cover" src="{{item.coverUrl}}" mode="aspectFill" lazy-load></image>
              <view wx:else class="author-works__placeholder" style="background: {{item.templatePalette}}">{{item.templateShortName}}</view>
              <text class="author-works__name">{{item.templateName}}</text>
            </view>
          </view>
        </scroll-view>
      </view>

      <!-- Showcase 页底部固定 dock 已有「用同款风格创作」，此处隐藏避免重复 -->
      <view wx:if="{{!showcase}}" class="job-row-actions {{!demo && job.results.length > 1 ? '' : 'job-row-actions--single'}}">
        <view wx:if="{{!demo && job.results.length > 1}}" class="job-row-actions__cell">
          <button class="primary-button job-row-btn" loading="{{saving}}" disabled="{{saving}}" bindtap="saveAll">保存全部作品</button>
        </view>
        <view class="job-row-actions__cell">
          <button class="{{!demo && job.results.length > 1 ? 'ghost-button' : 'primary-button'}} job-row-btn" bindtap="createAgain">{{demo ? '再练一次' : '继续创作'}}</button>
        </view>
      </view>

      <view wx:if="{{!demo && !showcase && shareRewardEnabled && (shareFriendTip || shareTimelineTip)}}" class="share-reward-panel">
        <view class="share-reward-panel__title">分享领积分</view>
        <view wx:if="{{shareFriendTip}}" class="share-reward-panel__row">
          <text class="share-reward-panel__channel">微信好友</text>
          <text class="share-reward-panel__detail">{{shareFriendTip}}</text>
        </view>
        <view wx:if="{{shareTimelineTip}}" class="share-reward-panel__row">
          <text class="share-reward-panel__channel">朋友圈</text>
          <text class="share-reward-panel__detail">{{shareTimelineTip}}</text>
        </view>
        <view class="share-reward-panel__note">同一作品同一渠道每天最多领 1 次；好友打开链接并登录/完成首作，你还可获得邀请奖励</view>
      </view>
      <view wx:if="{{!demo && !showcase}}" class="share-actions">
        <view class="share-action-cell">
          <button class="share-action" open-type="share" disabled="{{!share}}">
            <image class="share-action__icon" src="/assets/icons/share.png" mode="aspectFit"></image>
            <text class="share-action__label">微信好友</text>
            <text wx:if="{{shareFriendCredits > 0}}" class="share-action__sub">+{{shareFriendCredits}}分</text>
          </button>
        </view>
        <view class="share-action-cell">
          <view class="share-action" data-url="{{job.results[0].url}}" bindtap="shareImage">
            <image class="share-action__icon" src="/assets/icons/moments.png" mode="aspectFit"></image>
            <text class="share-action__label">朋友圈</text>
            <text wx:if="{{shareTimelineCredits > 0}}" class="share-action__sub">+{{shareTimelineCredits}}分</text>
          </view>
        </view>
        <view class="share-action-cell">
          <view class="share-action" bindtap="showQrCode">
            <image class="share-action__icon" src="/assets/icons/qr-code.png" mode="aspectFit"></image>
            <text class="share-action__label">小程序码</text>
          </view>
        </view>
        <view class="share-action-cell">
          <view class="share-action" bindtap="copyUrlLink">
            <image class="share-action__icon" src="/assets/icons/link.png" mode="aspectFit"></image>
            <text class="share-action__label">复制链接</text>
          </view>
        </view>
      </view>
      <view wx:elif="{{demo}}" class="demo-banner" style="margin-top: 20rpx">演示结果使用风格封面示意。返回首页后可对真实模板正式生成。</view>
    </view>

    <!-- Failed: only retry + home on one row -->
    <view wx:if="{{job.status === 'failed'}}" class="job-row-actions job-fail-actions">
      <view class="job-row-actions__cell">
        <button class="primary-button job-row-btn" loading="{{retrying}}" disabled="{{retrying}}" bindtap="retryJob">重试生成</button>
      </view>
      <view class="job-row-actions__cell">
        <button class="ghost-button job-row-btn" bindtap="goHome">返回首页</button>
      </view>
    </view>

    <!-- Waiting: view works + home -->
    <view wx:if="{{isWaiting}}" class="job-footer-actions job-row-actions">
      <view class="job-row-actions__cell">
        <button class="ghost-button job-row-btn" bindtap="goWorks">查看作品</button>
      </view>
      <view class="job-row-actions__cell">
        <button class="primary-button job-row-btn" bindtap="goHome">返回首页</button>
      </view>
    </view>
    <!-- Showcase / 花海: fixed bottom dock — create + like / like count -->
    <view wx:elif="{{showcase && !demo && job.status === 'succeeded'}}" class="showcase-dock">
      <button class="showcase-dock__create" bindtap="createAgain">用同款风格创作</button>
      <view wx:if="{{isOwner}}" class="showcase-dock__stats" aria-label="点赞数">
        <image class="showcase-dock__icon" src="/assets/icons/like-active.png" mode="aspectFit"></image>
        <view class="showcase-dock__stats-text">
          <text class="showcase-dock__count">{{likeCount}}</text>
          <text class="showcase-dock__label">次点赞</text>
        </view>
      </view>
      <view
        wx:else
        class="showcase-dock__like {{likedByMe ? 'is-liked' : ''}} {{liking ? 'is-loading' : ''}}"
        bindtap="onShowcaseLike"
      >
        <image class="showcase-dock__icon" src="{{likedByMe ? '/assets/icons/like-active.png' : '/assets/icons/like.png'}}" mode="aspectFit"></image>
        <view class="showcase-dock__stats-text">
          <text class="showcase-dock__count">{{likeCount}}</text>
          <text class="showcase-dock__label">{{likedByMe ? '已赞' : '点赞'}}{{(!likedByMe && galleryLikeLikerCredits > 0) ? ' +' : ''}}{{(!likedByMe && galleryLikeLikerCredits > 0) ? galleryLikeLikerCredits : ''}}</text>
        </view>
      </view>
    </view>
    <view wx:elif="{{job.status === 'succeeded'}}" class="job-footer-actions job-row-actions job-row-actions--single">
      <view class="job-row-actions__cell">
        <button class="primary-button job-row-btn" bindtap="goHome">{{demo ? '结束练习，去首页正式创作' : '返回首页'}}</button>
      </view>
    </view>

    <view wx:if="{{showQr}}" class="qr-mask" bindtap="hideQrCode">
      <view class="qr-dialog" catchtap="noop">
        <view class="qr-title">扫码打开这组作品</view>
        <image class="qr-image" src="{{share.qrcodeUrl}}" mode="aspectFit"></image>
        <view class="qr-subtitle">长按小程序码即可分享</view>
        <button class="ghost-button" bindtap="hideQrCode">关闭</button>
      </view>
    </view>
  </block>
</view>

.job-page {
  padding-bottom: 80rpx;
}

.status-block {
  min-height: 180rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
  background: var(--mint-soft);
  border: 2rpx solid #d8eee7;
  border-radius: 16rpx;
  color: #44665e;
}

.status-block--succeeded {
  background: var(--pink-soft);
  border-color: #f5dce1;
  color: #76545c;
}

.status-block--failed {
  background: #fff0ed;
  border-color: #f4d6cf;
  color: #8a574d;
}

.status-index {
  width: 78rpx;
  height: 78rpx;
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border: 8rpx solid rgba(255, 217, 120, 0.72);
  border-radius: 50%;
  color: var(--coral);
  font-size: 20rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(99, 79, 85, 0.08);
}

.status-main {
  min-width: 0;
  flex: 1;
}

.status-title {
  font-size: 34rpx;
  font-weight: 650;
}

.status-sub {
  margin-top: 10rpx;
  color: currentColor;
  opacity: 0.72;
  font-size: 20rpx;
  line-height: 1.55;
}

.spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid rgba(88, 173, 153, 0.2);
  border-top-color: var(--green);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.job-meta {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  overflow: hidden;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
  box-shadow: 0 10rpx 26rpx rgba(108, 82, 92, 0.05);
}

.job-meta view {
  min-width: 0;
  padding: 24rpx 10rpx;
  text-align: center;
  border-right: 2rpx solid var(--line);
}

.job-meta view:last-child { border-right: 0; }
.job-meta text { display: block; color: var(--muted); font-size: 18rpx; }
.job-meta__value { display: block; margin-top: 7rpx; color: var(--ink) !important; font-size: 22rpx !important; font-weight: 650; }

.result-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.result-item {
  position: relative;
  padding: 10rpx;
  overflow: hidden;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
  box-shadow: 0 12rpx 30rpx rgba(110, 83, 94, 0.07);
}

.result-item image {
  width: 100%;
  display: block;
  border-radius: 10rpx;
}

.result-number {
  position: absolute;
  right: 24rpx;
  bottom: 96rpx;
  padding: 7rpx 13rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 8rpx;
  color: var(--coral);
  font-size: 18rpx;
  font-weight: 650;
}

.result-actions {
  height: 72rpx;
  padding-top: 10rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
}

.result-actions button {
  height: 58rpx;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: var(--mint-soft);
  color: var(--green);
  font-size: 20rpx;
  line-height: 58rpx;
}

.result-actions button:last-child { background: var(--pink-soft); color: var(--coral); }
.result-actions image { width: 28rpx; height: 28rpx; }

.save-button { margin: 30rpx 0 18rpx; }
.share-actions { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 10rpx; }
.share-actions button { min-width: 0; height: 112rpx; margin: 0; padding: 12rpx 4rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8rpx; background: #fff; border: 2rpx solid var(--line); color: var(--ink); font-size: 18rpx; line-height: 1.2; }
.share-actions button[disabled] { opacity: .5; }
.share-actions image { width: 34rpx; height: 34rpx; }
.create-again-button { margin-top: 16rpx; }
.job-actions { margin-top: 42rpx; }
.job-actions .ghost-button { margin-top: 16rpx; }

.qr-mask { position: fixed; inset: 0; z-index: 80; padding: 40rpx; display: flex; align-items: center; justify-content: center; background: rgba(52, 49, 54, .5); }
.qr-dialog { width: 560rpx; padding: 34rpx; background: #fff; border-radius: 16rpx; text-align: center; box-shadow: 0 30rpx 80rpx rgba(55, 39, 45, .2); }
.qr-title { font-size: 30rpx; font-weight: 650; }
.qr-image { width: 390rpx; height: 390rpx; margin: 24rpx auto 12rpx; display: block; }
.qr-subtitle { margin-bottom: 24rpx; color: var(--muted); font-size: 20rpx; }

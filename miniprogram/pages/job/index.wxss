.job-page {
  padding-bottom: calc(env(safe-area-inset-bottom) + 48rpx);
}

.job-meta {
  margin-top: 8rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  overflow: hidden;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
  box-shadow: 0 10rpx 26rpx rgba(108, 82, 92, 0.05);
}

.generating {
  margin-top: 24rpx;
  padding: 56rpx 36rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  background: linear-gradient(165deg, #2f433d 0%, #3d5550 48%, #5a6e68 100%);
  border-radius: 20rpx;
  box-shadow: 0 16rpx 40rpx rgba(47, 67, 61, 0.18);
  color: #fff;
}

.progress-flower {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 28rpx;
  animation: flower-spin 4.5s linear infinite;
}

.progress-petal {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 56rpx;
  height: 80rpx;
  margin-left: -28rpx;
  margin-top: -70rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 50%;
  transform-origin: 50% 88%;
}

.progress-petal--1 { transform: rotate(0deg); }
.progress-petal--2 { transform: rotate(90deg); }
.progress-petal--3 { transform: rotate(180deg); }
.progress-petal--4 { transform: rotate(270deg); }

.progress-dot {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 2;
  width: 40rpx;
  height: 40rpx;
  margin-left: -20rpx;
  margin-top: -20rpx;
  background: var(--yellow);
  border: 6rpx solid #fff;
  border-radius: 50%;
  box-sizing: border-box;
}

.generating-title {
  font-family: "Kaiti SC", "STKaiti", "Songti SC", serif;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.3;
}

.generating-status {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
}

.generating-tip {
  margin-top: 22rpx;
  min-height: 72rpx;
  padding: 0 12rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 26rpx;
  line-height: 1.55;
  transition: opacity 0.3s ease;
}

.progress-track {
  width: 78%;
  height: 8rpx;
  margin-top: 28rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.22);
  border-radius: 999rpx;
}

.progress-track__bar {
  width: 42%;
  height: 100%;
  background: linear-gradient(90deg, #ffd978, #fff);
  border-radius: 999rpx;
  animation: progress-slide 1.8s ease-in-out infinite;
}

.generating-note {
  margin-top: 28rpx;
  max-width: 520rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: 20rpx;
  line-height: 1.6;
}

@keyframes flower-spin {
  to { transform: rotate(360deg); }
}

@keyframes progress-slide {
  0% { transform: translateX(-120%); }
  100% { transform: translateX(280%); }
}

.status-block {
  margin-top: 24rpx;
  min-height: 160rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
  background: var(--mint-soft);
  border: 2rpx solid #d8eee7;
  border-radius: 16rpx;
  color: #44665e;
}

.status-block--succeeded {
  background: var(--pink-soft);
  border-color: #f5dce1;
  color: #76545c;
}

.status-block--failed {
  background: #fff0ed;
  border-color: #f4d6cf;
  color: #8a574d;
}

/* Cute fail card */
.fail-card {
  margin-top: 24rpx;
  padding: 48rpx 36rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  background: linear-gradient(165deg, #fff8f6 0%, #fff0ed 55%, #fef6f0 100%);
  border: 2rpx solid #f4d6cf;
  border-radius: 20rpx;
  box-shadow: 0 12rpx 32rpx rgba(138, 87, 77, 0.08);
}

.fail-illus {
  position: relative;
  width: 160rpx;
  height: 140rpx;
  margin-bottom: 12rpx;
}

.fail-flower {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto;
  opacity: 0.92;
}

.fail-petal {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 42rpx;
  height: 58rpx;
  margin-left: -21rpx;
  margin-top: -52rpx;
  background: linear-gradient(180deg, #ffd4dc, #f2a4b1);
  border-radius: 50%;
  transform-origin: 50% 88%;
}

.fail-petal--1 { transform: rotate(0deg); opacity: 0.85; }
.fail-petal--2 { transform: rotate(90deg); background: linear-gradient(180deg, #ffe8c8, #ffb59c); }
.fail-petal--3 { transform: rotate(180deg) scale(0.92); opacity: 0.7; }
.fail-petal--4 { transform: rotate(270deg); background: linear-gradient(180deg, #e8e0f8, #c4b8dc); opacity: 0.8; }

.fail-dot {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 2;
  width: 32rpx;
  height: 32rpx;
  margin: -16rpx 0 0 -16rpx;
  background: #ffd978;
  border: 5rpx solid #fff;
  border-radius: 50%;
}

.fail-cloud {
  position: absolute;
  right: 8rpx;
  bottom: 8rpx;
  width: 48rpx;
  height: 28rpx;
  background: rgba(180, 160, 155, 0.25);
  border-radius: 999rpx;
}

.fail-title {
  margin-top: 8rpx;
  color: #7a4f48;
  font-family: "Kaiti SC", "STKaiti", "Songti SC", serif;
  font-size: 38rpx;
  font-weight: 700;
}

.fail-desc {
  margin-top: 14rpx;
  max-width: 520rpx;
  color: #9a6a62;
  font-size: 26rpx;
  line-height: 1.55;
}

.fail-refund {
  margin-top: 18rpx;
  padding: 12rpx 20rpx;
  background: var(--mint-soft);
  border-radius: 999rpx;
  color: var(--green);
  font-size: 22rpx;
  font-weight: 600;
}

.fail-unstable {
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  max-width: 560rpx;
  background: #fff8e7;
  border: 2rpx solid #f3ead1;
  border-radius: 12rpx;
  color: #8a7650;
  font-size: 22rpx;
  line-height: 1.55;
}

.job-fail-actions {
  margin-top: 28rpx;
}

.status-index {
  width: 78rpx;
  height: 78rpx;
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border: 8rpx solid rgba(255, 217, 120, 0.72);
  border-radius: 50%;
  color: var(--coral);
  font-size: 20rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(99, 79, 85, 0.08);
}

.status-main {
  min-width: 0;
  flex: 1;
}

.status-title {
  font-size: 34rpx;
  font-weight: 650;
}

.status-sub {
  margin-top: 10rpx;
  color: currentColor;
  opacity: 0.72;
  font-size: 20rpx;
  line-height: 1.55;
}

.job-meta view {
  min-width: 0;
  padding: 24rpx 10rpx;
  text-align: center;
  border-right: 2rpx solid var(--line);
}

.job-meta view:last-child { border-right: 0; }
.job-meta text { display: block; color: var(--muted); font-size: 18rpx; }
.job-meta__value { display: block; margin-top: 7rpx; color: var(--ink) !important; font-size: 22rpx !important; font-weight: 650; }

.result-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.result-item {
  position: relative;
  padding: 10rpx;
  overflow: hidden;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
  box-shadow: 0 12rpx 30rpx rgba(110, 83, 94, 0.07);
}

.result-item image {
  width: 100%;
  display: block;
  border-radius: 10rpx;
}

.result-number {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  padding: 7rpx 13rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 8rpx;
  color: var(--coral);
  font-size: 18rpx;
  font-weight: 650;
}

.original-section {
  margin-top: 12rpx;
}

.original-section__title {
  margin-top: 28rpx;
}

.original-scroll {
  width: 100%;
  white-space: nowrap;
}

.original-row {
  display: inline-flex;
  gap: 14rpx;
  padding-bottom: 8rpx;
}

.original-card {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  flex: none;
  overflow: hidden;
  background: #f0e9eb;
  border: 2rpx solid var(--line);
  border-radius: 14rpx;
  box-shadow: 0 8rpx 18rpx rgba(108, 82, 92, 0.06);
}

.original-card__image {
  display: block;
  width: 100%;
  height: 100%;
}

.original-card__label {
  position: absolute;
  right: 10rpx;
  bottom: 10rpx;
  left: 10rpx;
  padding: 6rpx 8rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 8rpx;
  color: var(--muted);
  font-size: 18rpx;
  text-align: center;
}

.result-actions {
  padding-top: 12rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
}

.result-actions button {
  height: 64rpx;
  margin: 0;
  padding: 0 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  background: var(--mint-soft);
  color: var(--green);
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1;
}

.result-actions button:last-child {
  background: var(--pink-soft);
  color: var(--coral);
}

.result-actions button::after {
  border: 0;
}

.action-icon {
  width: 30rpx;
  height: 30rpx;
  flex: none;
  display: block;
}

/* One row of two equal buttons; cells prevent WeChat button width overflow */
.job-row-actions {
  margin-top: 28rpx;
  display: flex;
  flex-direction: row;
  align-items: stretch;
  gap: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

.job-row-actions--single .job-row-actions__cell {
  flex: 1;
  width: 100%;
  max-width: 100%;
}

.job-row-actions__cell {
  flex: 1;
  width: 0;
  min-width: 0;
}

.job-row-btn {
  width: 100% !important;
  max-width: 100%;
  height: 88rpx !important;
  min-height: 88rpx;
  margin: 0 !important;
  padding: 0 12rpx !important;
  display: flex !important;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 26rpx;
  line-height: 1 !important;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.job-row-btn::after {
  border: 0;
}

/* Use flex cells so WeChat native buttons cannot overflow/overlap */
.share-reward-panel {
  margin: 18rpx 0 10rpx;
  padding: 18rpx 18rpx 16rpx;
  background: linear-gradient(135deg, #e9f7f2 0%, #fff8f5 100%);
  border: 2rpx solid #d9eee7;
  border-radius: 14rpx;
}

.share-reward-panel__title {
  margin-bottom: 12rpx;
  color: var(--green);
  font-size: 26rpx;
  font-weight: 700;
}

.share-reward-panel__row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-top: 8rpx;
}

.share-reward-panel__channel {
  flex: none;
  min-width: 120rpx;
  color: var(--ink);
  font-size: 22rpx;
  font-weight: 650;
}

.share-reward-panel__detail {
  flex: 1;
  min-width: 0;
  color: #4a7a6c;
  font-size: 22rpx;
  line-height: 1.45;
}

.share-reward-panel__note {
  margin-top: 12rpx;
  color: var(--muted);
  font-size: 18rpx;
  line-height: 1.5;
}

.public-share-panel {
  margin-top: 24rpx;
  padding: 28rpx 24rpx;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
  box-shadow: 0 10rpx 26rpx rgba(108, 82, 92, 0.05);
}
.public-share-panel__title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2a2f2d;
}
.public-share-panel__desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: var(--muted);
}
.public-share-row {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  font-size: 28rpx;
  color: #2a2f2d;
}
.public-share-row.is-disabled {
  opacity: 0.45;
}
.public-share-panel__note {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #8a6b19;
  line-height: 1.45;
}
.public-share-save {
  margin-top: 20rpx;
  width: 100%;
}

.public-share-reward-tip {
  margin-top: 12rpx;
  padding: 12rpx 14rpx;
  background: #fff8f0;
  border-radius: 10rpx;
  color: #9a7040;
  font-size: 22rpx;
  line-height: 1.45;
}

.avatar-panel {
  margin-top: 24rpx;
  padding: 28rpx 24rpx;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
  box-shadow: 0 10rpx 26rpx rgba(108, 82, 92, 0.05);
}

.avatar-panel__title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2a2f2d;
}

.avatar-panel__desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: var(--muted);
}

.avatar-shape-row {
  margin-top: 18rpx;
  display: flex;
  gap: 12rpx;
}

.avatar-shape {
  flex: 1;
  padding: 16rpx 0;
  text-align: center;
  border: 2rpx solid #eadfe3;
  border-radius: 12rpx;
  color: #6a6064;
  font-size: 26rpx;
  font-weight: 600;
}

.avatar-shape.is-active {
  border-color: #e76d82;
  background: #fff5f7;
  color: #e76d82;
}

.avatar-make-btn {
  margin-top: 18rpx;
  width: 100%;
}

.avatar-multi {
  margin-top: 16rpx;
}

.avatar-multi__label {
  font-size: 22rpx;
  color: var(--muted);
}

.avatar-multi__list {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.avatar-multi__item {
  padding: 8rpx 16rpx;
  background: #f6f2f3;
  border-radius: 999rpx;
  color: #5a5054;
  font-size: 22rpx;
}

.avatar-canvas-hidden {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 600px;
  height: 600px;
}

.showcase-like-bar {
  margin-top: 16rpx;
  padding: 20rpx 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
  box-shadow: 0 10rpx 26rpx rgba(108, 82, 92, 0.05);
}

.showcase-like-bar__author {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: var(--muted);
  font-size: 24rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.showcase-like-count {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 18rpx;
  background: #fff5f7;
  border-radius: 999rpx;
  color: #e04b66;
  font-size: 24rpx;
  font-weight: 650;
}

.showcase-like-count__icon {
  font-size: 28rpx;
  line-height: 1;
}

.showcase-like-btn {
  margin: 0;
  padding: 12rpx 22rpx;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #f8a0ad, #e76d82);
  border-radius: 999rpx;
  color: #fff;
  font-size: 24rpx;
  font-weight: 650;
  line-height: 1.2;
}

.showcase-like-btn::after {
  border: none;
}

.showcase-like-btn.is-liked,
.showcase-like-btn[disabled].is-liked {
  background: #ffe8ec;
  color: #e04b66;
  opacity: 1;
}

.showcase-like-btn__sub {
  opacity: 0.92;
  font-size: 20rpx;
  font-weight: 500;
}

.share-actions {
  margin-top: 16rpx;
  display: flex;
  flex-direction: row;
  align-items: stretch;
  gap: 12rpx;
  width: 100%;
  box-sizing: border-box;
}

.share-action-cell {
  flex: 1;
  width: 0;
  min-width: 0;
}

.share-action {
  width: 100% !important;
  max-width: 100%;
  height: 156rpx;
  margin: 0 !important;
  padding: 14rpx 4rpx 12rpx !important;
  display: flex !important;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  box-sizing: border-box;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
  color: var(--ink);
  font-size: 20rpx;
  font-weight: 500;
  line-height: 1.2 !important;
  box-shadow: 0 6rpx 16rpx rgba(108, 82, 92, 0.04);
}

button.share-action {
  /* Override WeChat button defaults that cause layout collapse */
  min-height: 156rpx;
  overflow: hidden;
}

.share-action::after {
  border: 0 !important;
}

.share-action[disabled] {
  opacity: 0.45;
}

.share-action__icon {
  width: 40rpx;
  height: 40rpx;
  flex: none;
  display: block;
}

.share-action__label {
  display: block;
  width: 100%;
  max-width: 100%;
  overflow: hidden;
  text-align: center;
  font-size: 20rpx;
  line-height: 1.25;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.share-action__sub {
  display: block;
  width: 100%;
  color: var(--coral);
  font-size: 18rpx;
  font-weight: 650;
  line-height: 1.2;
  text-align: center;
}

.job-actions {
  margin-top: 28rpx;
}

.job-delete-wrap {
  margin-top: 16rpx;
}

.job-delete-btn {
  width: 100%;
  height: 72rpx;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: 0;
  color: #c56f60;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 72rpx;
}

.job-delete-btn::after {
  border: 0;
}

.job-footer-actions {
  margin-top: 28rpx;
}

.qr-mask { position: fixed; inset: 0; z-index: 80; padding: 40rpx; display: flex; align-items: center; justify-content: center; background: rgba(52, 49, 54, .5); }
.qr-dialog { width: 560rpx; padding: 34rpx; background: #fff; border-radius: 16rpx; text-align: center; box-shadow: 0 30rpx 80rpx rgba(55, 39, 45, .2); }
.qr-title { font-size: 30rpx; font-weight: 650; }
.qr-image { width: 390rpx; height: 390rpx; margin: 24rpx auto 12rpx; display: block; }
.qr-subtitle { margin-bottom: 24rpx; color: var(--muted); font-size: 20rpx; }

.job-page {
  padding-bottom: calc(env(safe-area-inset-bottom) + 48rpx);
}

.job-meta {
  margin-top: 8rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  overflow: hidden;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
  box-shadow: 0 10rpx 26rpx rgba(108, 82, 92, 0.05);
}

.generating {
  margin-top: 24rpx;
  padding: 56rpx 36rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  background: linear-gradient(165deg, #2f433d 0%, #3d5550 48%, #5a6e68 100%);
  border-radius: 20rpx;
  box-shadow: 0 16rpx 40rpx rgba(47, 67, 61, 0.18);
  color: #fff;
}

.progress-flower {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 28rpx;
  animation: flower-spin 4.5s linear infinite;
}

.progress-petal {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 56rpx;
  height: 80rpx;
  margin-left: -28rpx;
  margin-top: -70rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 50%;
  transform-origin: 50% 88%;
}

.progress-petal--1 { transform: rotate(0deg); }
.progress-petal--2 { transform: rotate(90deg); }
.progress-petal--3 { transform: rotate(180deg); }
.progress-petal--4 { transform: rotate(270deg); }

.progress-dot {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 2;
  width: 40rpx;
  height: 40rpx;
  margin-left: -20rpx;
  margin-top: -20rpx;
  background: var(--yellow);
  border: 6rpx solid #fff;
  border-radius: 50%;
  box-sizing: border-box;
}

.generating-title {
  font-family: "Kaiti SC", "STKaiti", "Songti SC", serif;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.3;
}

.generating-status {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
}

.generating-tip {
  margin-top: 22rpx;
  min-height: 72rpx;
  padding: 0 12rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 26rpx;
  line-height: 1.55;
  transition: opacity 0.3s ease;
}

.progress-track {
  width: 78%;
  height: 8rpx;
  margin-top: 28rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.22);
  border-radius: 999rpx;
}

.progress-track__bar {
  width: 42%;
  height: 100%;
  background: linear-gradient(90deg, #ffd978, #fff);
  border-radius: 999rpx;
  animation: progress-slide 1.8s ease-in-out infinite;
}

.generating-note {
  margin-top: 28rpx;
  max-width: 520rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: 20rpx;
  line-height: 1.6;
}

@keyframes flower-spin {
  to { transform: rotate(360deg); }
}

@keyframes progress-slide {
  0% { transform: translateX(-120%); }
  100% { transform: translateX(280%); }
}

.status-block {
  margin-top: 24rpx;
  min-height: 160rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
  background: var(--mint-soft);
  border: 2rpx solid #d8eee7;
  border-radius: 16rpx;
  color: #44665e;
}

.status-block--succeeded {
  background: var(--pink-soft);
  border-color: #f5dce1;
  color: #76545c;
}

.status-block--failed {
  background: #fff0ed;
  border-color: #f4d6cf;
  color: #8a574d;
}

.status-index {
  width: 78rpx;
  height: 78rpx;
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border: 8rpx solid rgba(255, 217, 120, 0.72);
  border-radius: 50%;
  color: var(--coral);
  font-size: 20rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(99, 79, 85, 0.08);
}

.status-main {
  min-width: 0;
  flex: 1;
}

.status-title {
  font-size: 34rpx;
  font-weight: 650;
}

.status-sub {
  margin-top: 10rpx;
  color: currentColor;
  opacity: 0.72;
  font-size: 20rpx;
  line-height: 1.55;
}

.job-meta view {
  min-width: 0;
  padding: 24rpx 10rpx;
  text-align: center;
  border-right: 2rpx solid var(--line);
}

.job-meta view:last-child { border-right: 0; }
.job-meta text { display: block; color: var(--muted); font-size: 18rpx; }
.job-meta__value { display: block; margin-top: 7rpx; color: var(--ink) !important; font-size: 22rpx !important; font-weight: 650; }

.result-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.result-item {
  position: relative;
  padding: 10rpx;
  overflow: hidden;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
  box-shadow: 0 12rpx 30rpx rgba(110, 83, 94, 0.07);
}

.result-item image {
  width: 100%;
  display: block;
  border-radius: 10rpx;
}

.result-number {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  padding: 7rpx 13rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 8rpx;
  color: var(--coral);
  font-size: 18rpx;
  font-weight: 650;
}

.original-section {
  margin-top: 12rpx;
}

.original-section__title {
  margin-top: 28rpx;
}

.original-scroll {
  width: 100%;
  white-space: nowrap;
}

.original-row {
  display: inline-flex;
  gap: 14rpx;
  padding-bottom: 8rpx;
}

.original-card {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  flex: none;
  overflow: hidden;
  background: #f0e9eb;
  border: 2rpx solid var(--line);
  border-radius: 14rpx;
  box-shadow: 0 8rpx 18rpx rgba(108, 82, 92, 0.06);
}

.original-card__image {
  display: block;
  width: 100%;
  height: 100%;
}

.original-card__label {
  position: absolute;
  right: 10rpx;
  bottom: 10rpx;
  left: 10rpx;
  padding: 6rpx 8rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 8rpx;
  color: var(--muted);
  font-size: 18rpx;
  text-align: center;
}

.result-actions {
  padding-top: 12rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
}

.result-actions button {
  height: 64rpx;
  margin: 0;
  padding: 0 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  background: var(--mint-soft);
  color: var(--green);
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1;
}

.result-actions button:last-child {
  background: var(--pink-soft);
  color: var(--coral);
}

.result-actions button::after {
  border: 0;
}

.action-icon {
  width: 30rpx;
  height: 30rpx;
  flex: none;
  display: block;
}

/* One row of two equal buttons; cells prevent WeChat button width overflow */
.job-row-actions {
  margin-top: 28rpx;
  display: flex;
  flex-direction: row;
  align-items: stretch;
  gap: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

.job-row-actions--single .job-row-actions__cell {
  flex: 1;
  width: 100%;
  max-width: 100%;
}

.job-row-actions__cell {
  flex: 1;
  width: 0;
  min-width: 0;
}

.job-row-btn {
  width: 100% !important;
  max-width: 100%;
  height: 88rpx !important;
  min-height: 88rpx;
  margin: 0 !important;
  padding: 0 12rpx !important;
  display: flex !important;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 26rpx;
  line-height: 1 !important;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.job-row-btn::after {
  border: 0;
}

/* Use flex cells so WeChat native buttons cannot overflow/overlap */
.share-actions {
  margin-top: 22rpx;
  display: flex;
  flex-direction: row;
  align-items: stretch;
  gap: 12rpx;
  width: 100%;
  box-sizing: border-box;
}

.share-action-cell {
  flex: 1;
  width: 0;
  min-width: 0;
}

.share-action {
  width: 100% !important;
  max-width: 100%;
  height: 140rpx;
  margin: 0 !important;
  padding: 16rpx 4rpx 14rpx !important;
  display: flex !important;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  box-sizing: border-box;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
  color: var(--ink);
  font-size: 20rpx;
  font-weight: 500;
  line-height: 1.2 !important;
  box-shadow: 0 6rpx 16rpx rgba(108, 82, 92, 0.04);
}

button.share-action {
  /* Override WeChat button defaults that cause layout collapse */
  min-height: 140rpx;
  overflow: hidden;
}

.share-action::after {
  border: 0 !important;
}

.share-action[disabled] {
  opacity: 0.45;
}

.share-action__icon {
  width: 40rpx;
  height: 40rpx;
  flex: none;
  display: block;
}

.share-action__label {
  display: block;
  width: 100%;
  max-width: 100%;
  overflow: hidden;
  text-align: center;
  font-size: 20rpx;
  line-height: 1.25;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.job-actions {
  margin-top: 28rpx;
}

.job-footer-actions {
  margin-top: 28rpx;
}

.qr-mask { position: fixed; inset: 0; z-index: 80; padding: 40rpx; display: flex; align-items: center; justify-content: center; background: rgba(52, 49, 54, .5); }
.qr-dialog { width: 560rpx; padding: 34rpx; background: #fff; border-radius: 16rpx; text-align: center; box-shadow: 0 30rpx 80rpx rgba(55, 39, 45, .2); }
.qr-title { font-size: 30rpx; font-weight: 650; }
.qr-image { width: 390rpx; height: 390rpx; margin: 24rpx auto 12rpx; display: block; }
.qr-subtitle { margin-bottom: 24rpx; color: var(--muted); font-size: 20rpx; }

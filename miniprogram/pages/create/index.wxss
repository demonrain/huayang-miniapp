.create-page {
  padding-bottom: calc(env(safe-area-inset-bottom) + 180rpx);
}

.selected-style {
  min-height: 168rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
  background: var(--surface);
  border: 2rpx solid var(--line);
  border-radius: 8rpx;
}

.style-swatch {
  width: 126rpx;
  height: 126rpx;
  flex: none;
  padding: 12rpx;
  display: flex;
  align-items: flex-end;
  color: #fff;
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  font-weight: 700;
}

.style-copy {
  min-width: 0;
  flex: 1;
}

.eyebrow {
  color: var(--muted);
  font-size: 20rpx;
}

.style-name {
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.style-desc {
  margin-top: 8rpx;
  overflow: hidden;
  color: var(--muted);
  font-size: 22rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.unit-cost {
  align-self: flex-start;
  color: var(--coral);
  font-size: 20rpx;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.photo-item,
.add-photo {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  min-width: 0;
  margin: 0;
  padding: 0;
  overflow: hidden;
  border-radius: 8rpx;
}

.photo-item image {
  width: 100%;
  height: 100%;
}

.remove-button {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 42rpx;
  height: 42rpx;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(24, 27, 25, 0.8);
  border-radius: 50%;
  color: #fff;
  font-size: 30rpx;
  font-weight: 400;
  line-height: 42rpx;
}

.photo-number {
  position: absolute;
  left: 10rpx;
  bottom: 10rpx;
  width: 34rpx;
  height: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  color: var(--ink);
  font-size: 18rpx;
}

.add-photo {
  min-height: 214rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: 2rpx dashed #b9b8b2;
  color: var(--ink);
  font-size: 24rpx;
  line-height: 1.5;
}

.add-photo text {
  margin-top: 4rpx;
  color: var(--muted);
  font-size: 18rpx;
}

.add-icon {
  font-size: 46rpx;
  font-weight: 300;
}

.photo-note {
  margin-top: 28rpx;
  padding: 22rpx;
  display: flex;
  gap: 16rpx;
  background: #eee9dc;
  color: #5f5a50;
  font-size: 22rpx;
  line-height: 1.7;
}

.note-mark {
  flex: none;
  color: var(--green);
  font-weight: 700;
}

.bottom-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  min-height: 144rpx;
  padding: 22rpx 28rpx calc(env(safe-area-inset-bottom) + 22rpx);
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 254, 251, 0.97);
  border-top: 2rpx solid var(--line);
}

.cost-label {
  color: var(--muted);
  font-size: 20rpx;
}

.cost-value {
  margin-top: 4rpx;
  font-family: Georgia, serif;
  font-size: 38rpx;
  font-weight: 700;
}

.cost-value text {
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx;
  font-weight: 400;
}

.generate-button {
  width: 340rpx;
  height: 88rpx;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--green);
  color: #fff;
  line-height: 88rpx;
}

.generate-button[disabled] {
  background: #bfc4c0;
  color: #fff;
}


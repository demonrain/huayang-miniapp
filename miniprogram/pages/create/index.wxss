.create-page {
  padding-bottom: calc(env(safe-area-inset-bottom) + 190rpx);
}

.step-line {
  margin-bottom: 24rpx;
  display: flex;
  gap: 16rpx;
}

.step-line__item {
  padding: 10rpx 18rpx;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: 999rpx;
  color: var(--muted);
  font-size: 20rpx;
}

.step-line__item--active {
  background: var(--pink-soft);
  border-color: #f2a4b1;
  color: var(--coral);
  font-weight: 650;
}

.selected-style {
  position: relative;
  min-height: 176rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
  box-shadow: 0 12rpx 30rpx rgba(109, 81, 92, 0.06);
}

.style-swatch {
  position: relative;
  width: 132rpx;
  height: 132rpx;
  flex: none;
  padding: 12rpx;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
  border-radius: 12rpx;
  color: #5b4d53;
}

.style-swatch__image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.style-swatch text {
  position: relative;
  z-index: 3;
  padding: 4rpx 8rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 6rpx;
  color: #5b4d53;
  font-family: "Kaiti SC", "STKaiti", serif;
  font-size: 23rpx;
  font-weight: 700;
}

.swatch-paper {
  position: absolute;
  top: 22rpx;
  left: 34rpx;
  width: 72rpx;
  height: 84rpx;
  background: rgba(255,255,255,0.86);
  border: 6rpx solid #fff;
  box-shadow: 0 6rpx 12rpx rgba(97, 73, 81, 0.1);
  transform: rotate(-6deg);
}

.swatch-tape {
  position: absolute;
  top: 16rpx;
  left: 52rpx;
  z-index: 2;
  width: 50rpx;
  height: 16rpx;
  background: rgba(255, 235, 170, 0.9);
  transform: rotate(3deg);
}

.style-copy {
  min-width: 0;
  flex: 1;
}

.eyebrow {
  color: var(--coral);
  font-size: 19rpx;
  font-weight: 600;
}

.style-name {
  margin-top: 8rpx;
  font-size: 29rpx;
  font-weight: 650;
}

.style-desc {
  margin-top: 8rpx;
  overflow: hidden;
  color: var(--muted);
  font-size: 21rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.unit-cost {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 6rpx 10rpx;
  background: var(--pink-soft);
  border-radius: 8rpx;
  color: var(--coral);
  font-size: 17rpx;
}

.photo-subtitle {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 20rpx;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

/* Equal square cells for both previews and the add tile */
.photo-cell {
  position: relative;
  width: calc((100% - 28rpx) / 3);
  height: 0;
  padding-bottom: calc((100% - 28rpx) / 3);
  overflow: hidden;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.photo-cell__inner {
  position: absolute;
  inset: 0;
  overflow: hidden;
  border-radius: 16rpx;
}

.photo-item .photo-cell__inner {
  background: #fff;
  border: 2rpx solid var(--line);
  box-shadow: 0 8rpx 20rpx rgba(113, 87, 96, 0.08);
}

.photo-item__image {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 14rpx;
}

.remove-button {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  z-index: 3;
  width: 40rpx;
  height: 40rpx;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(231, 109, 130, 0.94);
  border-radius: 50%;
  color: #fff;
  font-size: 28rpx;
  font-weight: 400;
  line-height: 1;
  box-shadow: 0 4rpx 10rpx rgba(231, 109, 130, 0.28);
}

.photo-number {
  position: absolute;
  left: 10rpx;
  bottom: 10rpx;
  z-index: 2;
  width: 34rpx;
  height: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 50%;
  color: var(--coral);
  font-size: 17rpx;
  font-weight: 700;
  line-height: 1;
}

.add-photo .photo-cell__inner,
.add-photo__inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--pink-soft);
  border: 2rpx dashed #efa9b5;
  color: #6b5d63;
}

.add-photo__title {
  margin-top: 4rpx;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.3;
}

.add-photo__sub {
  margin-top: 4rpx;
  color: var(--muted);
  font-size: 18rpx;
  line-height: 1.3;
}

.camera-icon {
  position: relative;
  width: 54rpx;
  height: 42rpx;
  margin-bottom: 12rpx;
  border: 4rpx solid var(--coral);
  border-radius: 8rpx;
}

.camera-icon::before {
  content: '';
  position: absolute;
  top: -12rpx;
  left: 13rpx;
  width: 24rpx;
  height: 12rpx;
  background: var(--coral);
  border-radius: 5rpx 5rpx 0 0;
}

.camera-lens {
  position: absolute;
  top: 8rpx;
  left: 15rpx;
  width: 18rpx;
  height: 18rpx;
  border: 4rpx solid var(--coral);
  border-radius: 50%;
}

.photo-note {
  margin-top: 28rpx;
  padding: 22rpx;
  display: flex;
  gap: 16rpx;
  background: var(--mint-soft);
  border-radius: 14rpx;
  color: #688179;
  font-size: 21rpx;
  line-height: 1.65;
}

.note-mark {
  flex: none;
  color: var(--green);
  font-weight: 650;
}

.bottom-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  min-height: 148rpx;
  padding: 22rpx 30rpx calc(env(safe-area-inset-bottom) + 22rpx);
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.97);
  border-top: 2rpx solid var(--line);
  box-shadow: 0 -10rpx 30rpx rgba(108, 80, 91, 0.06);
}

.cost-label {
  color: var(--muted);
  font-size: 19rpx;
}

.cost-value {
  margin-top: 4rpx;
  color: var(--coral);
  font-family: Georgia, serif;
  font-size: 38rpx;
  font-weight: 700;
}

.cost-value text {
  font-family: "PingFang SC", sans-serif;
  font-size: 19rpx;
  font-weight: 400;
}

.cost-eta {
  margin-top: 6rpx;
  color: var(--muted);
  font-size: 18rpx;
  line-height: 1.4;
  max-width: 260rpx;
}

.eta-banner {
  margin: 8rpx 0 20rpx;
  padding: 14rpx 18rpx;
  background: var(--mint-soft);
  border-radius: 12rpx;
  color: var(--green);
  font-size: 22rpx;
  font-weight: 600;
  text-align: center;
  line-height: 1.45;
}

.generate-button {
  min-width: 320rpx;
  max-width: 440rpx;
  height: 88rpx;
  margin: 0;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  background: var(--coral);
  box-shadow: 0 12rpx 26rpx rgba(231, 109, 130, 0.2);
  color: #fff;
  font-size: 28rpx;
  line-height: 1;
  white-space: nowrap;
}

.generate-button__icon {
  width: 34rpx;
  height: 34rpx;
  flex: none;
}

.generate-button[disabled] {
  background: #e5dadd;
  box-shadow: none;
  color: #a89ca0;
}

.generate-button[disabled] .generate-button__icon {
  opacity: 0.55;
}

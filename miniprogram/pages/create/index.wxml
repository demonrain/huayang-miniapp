<view class="page create-page page-enter" style="padding-top: {{navSpacer}}rpx">
  <custom-nav show-back credits="{{credits}}"></custom-nav>

  <block wx:if="{{template}}">
    <view wx:if="{{demo}}" class="demo-banner">练习模式 · 界面与正式一致 · 确认生成不会上传、不扣积分</view>
    <view class="step-line">
      <text class="step-line__item step-line__item--active">选择照片</text>
      <text class="step-line__item">确认效果</text>
      <text class="step-line__item">生成作品</text>
    </view>

    <view class="selected-style">
      <view class="style-swatch" style="background: {{template.palette}}">
        <image wx:if="{{template.coverUrl}}" class="style-swatch__image" src="{{template.coverUrl}}" mode="aspectFill"></image>
        <block wx:else>
          <view class="swatch-paper"></view>
          <view class="swatch-tape"></view>
        </block>
        <text>{{template.shortName}}</text>
      </view>
      <view class="style-copy">
        <view class="eyebrow">本次创作</view>
        <view class="style-name">{{template.name}}</view>
        <view class="style-desc">{{template.description}}</view>
      </view>
      <view class="unit-cost">{{template.cost}} 积分/张</view>
    </view>

    <view class="section-title">
      <view>
        <view class="section-title__main">选几张喜欢的照片</view>
        <view class="photo-subtitle">{{demo ? '已放入示例照片，可直接继续或替换' : '清晰自然的原图会更好看 · 最多 ' + maxFiles + ' 张'}}</view>
      </view>
      <view class="section-title__sub">{{files.length}} / {{maxFiles}}</view>
    </view>

    <view class="photo-grid">
      <view wx:for="{{files}}" wx:key="path" class="photo-cell photo-item">
        <view class="photo-cell__inner">
          <image class="photo-item__image" src="{{item.path}}" mode="aspectFill" data-path="{{item.path}}" bindtap="previewImage"></image>
          <view class="remove-button" data-index="{{index}}" catchtap="removeImage">×</view>
          <view class="photo-number">{{index + 1}}</view>
        </view>
      </view>
      <view wx:if="{{files.length < maxFiles}}" class="photo-cell add-photo" bindtap="chooseImages">
        <view class="photo-cell__inner add-photo__inner">
          <view class="camera-icon">
            <view class="camera-lens"></view>
          </view>
          <view class="add-photo__title">添加照片</view>
          <text class="add-photo__sub">相册或拍摄</text>
        </view>
      </view>
    </view>

    <view class="photo-note">
      <view class="note-mark">{{demo ? '练习说明' : '隐私保护'}}</view>
      <view wx:if="{{demo}}">当前是本地示例照片。你也可以换成自己的照片；练习过程始终不会上传服务器或扣除积分。</view>
      <view wx:else>照片仅用于本次创作。原图与生成结果由你管理，不会出现在公开广场。</view>
    </view>

    <view class="bottom-bar">
      <view>
        <view class="cost-label">{{demo ? '演示消耗' : '预计消耗'}}</view>
        <view class="cost-value">{{demo ? 0 : totalCost}} <text>积分</text></view>
      </view>
      <button
        class="generate-button"
        disabled="{{!files.length || busy}}"
        loading="{{busy}}"
        bindtap="generate"
      >
        <image wx:if="{{!busy}}" class="generate-button__icon" src="/assets/icons/wand-sparkles.png" mode="aspectFit"></image>
        <text>{{busy ? (demo ? '演示提交中' : '正在提交') : (files.length ? (demo ? '演示生成 · 不扣费' : ('确认生成 · ' + totalCost + ' 积分')) : '确认生成')}}</text>
      </button>
    </view>
  </block>
</view>

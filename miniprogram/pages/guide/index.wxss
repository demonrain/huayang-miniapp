.guide-page {
  min-height: 100vh;
  padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
}

.guide-loading {
  min-height: 720rpx;
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.guide-flower {
  position: relative;
  width: 150rpx;
  height: 150rpx;
  animation: guide-spin 4s linear infinite;
}

.guide-petal {
  position: absolute;
  width: 58rpx;
  height: 78rpx;
  background: #f28fa0;
  border-radius: 50%;
  transform-origin: 29rpx 66rpx;
}

.guide-petal--1 { top: 0; left: 46rpx; }
.guide-petal--2 { top: 46rpx; right: 0; transform: rotate(90deg); }
.guide-petal--3 { bottom: 0; left: 46rpx; transform: rotate(180deg); }
.guide-petal--4 { top: 46rpx; left: 0; transform: rotate(270deg); }

.guide-dot {
  position: absolute;
  top: 52rpx;
  left: 52rpx;
  z-index: 2;
  width: 46rpx;
  height: 46rpx;
  background: #ffd978;
  border: 8rpx solid #fff9f8;
  border-radius: 50%;
}

.guide-title {
  margin-top: 36rpx;
  color: #403b43;
  font-size: 34rpx;
  font-weight: 700;
}

.guide-desc {
  max-width: 580rpx;
  margin-top: 16rpx;
  color: #8d858d;
  font-size: 24rpx;
  line-height: 1.65;
}

.guide-button {
  width: 100%;
  margin-top: 28rpx;
}

.guide-button + .guide-button { margin-top: 14rpx; }

@keyframes guide-spin { to { transform: rotate(360deg); } }

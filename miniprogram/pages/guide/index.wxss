@import "../home/index.wxss";

.guide-page {
  padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
}

.demo-banner {
  margin: 8rpx 0 16rpx;
  padding: 14rpx 18rpx;
  background: var(--mint-soft);
  border: 2rpx solid #c8e8dc;
  border-radius: 12rpx;
  color: var(--green);
  font-size: 22rpx;
  text-align: center;
  font-weight: 600;
  line-height: 1.45;
}

.guide-intro {
  margin-top: 8rpx;
  padding: 32rpx 28rpx 24rpx;
}

.guide-intro__kicker {
  color: var(--coral);
  font-family: Georgia, serif;
  font-size: 18rpx;
  letter-spacing: 1rpx;
}

.guide-intro__title {
  margin-top: 10rpx;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.35;
  color: var(--ink);
}

.guide-intro__desc {
  margin-top: 14rpx;
  color: var(--muted);
  font-size: 24rpx;
  line-height: 1.6;
}

.guide-intro__steps {
  margin: 28rpx 0 0;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.guide-intro__step {
  display: flex;
  align-items: center;
  gap: 14rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--ink);
}

.guide-intro__step .n {
  width: 40rpx;
  height: 40rpx;
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #ffe8ec, #fff6e8);
  border-radius: 50%;
  color: var(--coral);
  font-family: Georgia, serif;
  font-size: 22rpx;
  font-weight: 700;
}

.guide-intro__gift {
  margin: 28rpx 0 20rpx;
  padding: 16rpx 18rpx;
  background: var(--mint-soft);
  border-radius: 12rpx;
  color: var(--green);
  font-size: 22rpx;
  text-align: center;
  line-height: 1.5;
}

.guide-skip {
  margin-top: 18rpx;
  text-align: center;
  color: var(--muted);
  font-size: 24rpx;
  padding: 12rpx;
}

.section-kicker {
  margin-top: 4rpx;
  color: var(--muted);
  font-size: 20rpx;
}

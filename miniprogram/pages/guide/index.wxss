.guide-page {
  padding-bottom: calc(env(safe-area-inset-bottom) + 48rpx);
}

/* —— Progress —— */
.guide-progress {
  display: flex;
  justify-content: space-between;
  gap: 8rpx;
  margin-bottom: 24rpx;
  padding: 16rpx 12rpx;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
}

.guide-progress__item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  color: var(--muted);
  font-size: 20rpx;
}

.guide-progress__dot {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f4eaec;
  color: var(--muted);
  font-size: 20rpx;
  font-weight: 700;
}

.guide-progress__item.is-active {
  color: var(--coral);
  font-weight: 650;
}

.guide-progress__item.is-active .guide-progress__dot {
  background: var(--pink-soft);
  color: var(--coral);
  border: 2rpx solid #f2a4b1;
}

.guide-progress__item.is-done {
  color: var(--green);
}

.guide-progress__item.is-done .guide-progress__dot {
  background: var(--mint-soft);
  color: var(--green);
  font-size: 18rpx;
}

/* —— Panels —— */
.guide-panel {
  animation: guide-fade 0.28s ease;
}

@keyframes guide-fade {
  from { opacity: 0; transform: translateY(12rpx); }
  to { opacity: 1; transform: none; }
}

.panel-tip {
  margin-bottom: 24rpx;
  padding: 24rpx 22rpx;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
  box-shadow: 0 10rpx 26rpx rgba(108, 82, 92, 0.05);
}

.panel-tip--success {
  background: linear-gradient(165deg, #fff 0%, #e9f7f2 100%);
  border-color: #c8e8dc;
}

.panel-tip__kicker {
  color: var(--coral);
  font-family: Georgia, serif;
  font-size: 18rpx;
  letter-spacing: 1rpx;
}

.panel-tip--success .panel-tip__kicker {
  color: var(--green);
}

.panel-tip__title {
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--ink);
}

.panel-tip__text {
  margin-top: 10rpx;
  color: var(--muted);
  font-size: 24rpx;
  line-height: 1.55;
}

/* —— Welcome —— */
.guide-welcome {
  padding-bottom: 24rpx;
}

.welcome-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0 12rpx;
}

.welcome-flower {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 20rpx;
}

.welcome-petal {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 48rpx;
  height: 68rpx;
  margin-left: -24rpx;
  margin-top: -60rpx;
  background: linear-gradient(180deg, #ffd4dc, #f28fa0);
  border-radius: 50%;
  transform-origin: 50% 88%;
  opacity: 0.92;
}

.welcome-petal--1 { transform: rotate(0deg); }
.welcome-petal--2 { transform: rotate(90deg); background: linear-gradient(180deg, #ffe8c8, #ffb59c); }
.welcome-petal--3 { transform: rotate(180deg); background: linear-gradient(180deg, #d8f0e8, #78c9b5); }
.welcome-petal--4 { transform: rotate(270deg); background: linear-gradient(180deg, #e8e0f8, #b9a9dc); }

.welcome-center {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 2;
  width: 36rpx;
  height: 36rpx;
  margin: -18rpx 0 0 -18rpx;
  background: var(--yellow);
  border: 5rpx solid #fff;
  border-radius: 50%;
  box-shadow: 0 4rpx 12rpx rgba(255, 185, 100, 0.4);
}

.welcome-badge {
  padding: 8rpx 20rpx;
  background: var(--mint-soft);
  border-radius: 999rpx;
  color: var(--green);
  font-size: 22rpx;
  font-weight: 600;
}

.welcome-title {
  margin-top: 20rpx;
  text-align: center;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.35;
  color: var(--ink);
}

.welcome-desc {
  margin-top: 16rpx;
  padding: 0 8rpx;
  text-align: center;
  color: var(--muted);
  font-size: 24rpx;
  line-height: 1.65;
}

.welcome-flow {
  margin: 32rpx 0 0;
  padding: 22rpx 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
}

.welcome-flow__item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  font-size: 20rpx;
  color: var(--ink);
  font-weight: 600;
}

.welcome-flow__num {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #ffe8ec, #fff6e8);
  border-radius: 50%;
  color: var(--coral);
  font-family: Georgia, serif;
  font-size: 22rpx;
  font-weight: 700;
}

.welcome-flow__arrow {
  color: #e0c8cc;
  font-size: 28rpx;
  flex: none;
  margin-bottom: 28rpx;
}

.welcome-gift {
  margin: 24rpx 0 20rpx;
  padding: 16rpx 18rpx;
  background: var(--mint-soft);
  border-radius: 12rpx;
  color: var(--green);
  font-size: 22rpx;
  text-align: center;
  line-height: 1.5;
}

.guide-cta {
  width: 100%;
}

.guide-skip {
  margin-top: 18rpx;
  text-align: center;
  color: var(--muted);
  font-size: 24rpx;
  padding: 12rpx;
}

/* —— Style cards —— */
.style-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.style-card {
  position: relative;
  display: flex;
  gap: 20rpx;
  padding: 16rpx;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
  box-shadow: 0 8rpx 22rpx rgba(108, 82, 92, 0.04);
  transition: border-color 0.15s ease, box-shadow 0.15s ease;
}

.style-card.is-selected {
  border-color: #f2a4b1;
  box-shadow: 0 10rpx 28rpx rgba(231, 109, 130, 0.12);
  background: #fffafb;
}

.style-card__cover {
  position: relative;
  width: 128rpx;
  height: 128rpx;
  flex: none;
  border-radius: 12rpx;
  overflow: hidden;
  display: flex;
  align-items: flex-end;
  padding: 10rpx;
}

.style-card__short {
  padding: 4rpx 10rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 6rpx;
  font-family: "Kaiti SC", "STKaiti", serif;
  font-size: 22rpx;
  font-weight: 700;
  color: #5b4d53;
}

.style-card__badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  padding: 2rpx 10rpx;
  background: rgba(255, 255, 255, 0.85);
  border-radius: 999rpx;
  font-size: 18rpx;
  color: var(--muted);
}

.style-card__body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.style-card__name {
  font-size: 30rpx;
  font-weight: 650;
}

.style-card__desc {
  margin-top: 6rpx;
  color: var(--muted);
  font-size: 22rpx;
  line-height: 1.4;
}

.style-card__cost {
  margin-top: 10rpx;
  color: var(--coral);
  font-size: 22rpx;
  font-weight: 600;
}

.style-card__check {
  position: absolute;
  top: 14rpx;
  right: 14rpx;
  padding: 4rpx 12rpx;
  background: var(--coral);
  color: #fff;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 600;
}

/* —— Photos —— */
.section-label {
  margin: 8rpx 0 12rpx;
  color: var(--muted);
  font-size: 22rpx;
  font-weight: 600;
}

.demo-photo-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.demo-photo {
  flex: 1;
  min-height: 180rpx;
  padding: 16rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx solid transparent;
  border-radius: 14rpx;
  text-align: center;
  box-shadow: 0 6rpx 16rpx rgba(108, 82, 92, 0.05);
}

.demo-photo.is-selected {
  border-color: var(--coral);
  box-shadow: 0 8rpx 20rpx rgba(231, 109, 130, 0.14);
}

.demo-photo__emoji {
  font-size: 44rpx;
  line-height: 1.2;
}

.demo-photo__label {
  margin-top: 8rpx;
  font-size: 24rpx;
  font-weight: 650;
}

.demo-photo__hint {
  margin-top: 4rpx;
  color: var(--muted);
  font-size: 18rpx;
}

.real-photo-box {
  position: relative;
  min-height: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fff;
  border: 2rpx dashed #e0c8cc;
  border-radius: 16rpx;
  overflow: hidden;
}

.real-photo-box.is-selected {
  border-style: solid;
  border-color: var(--coral);
}

.real-photo-box__img {
  width: 100%;
  height: 240rpx;
}

.real-photo-box__mask {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12rpx;
  background: rgba(48, 40, 44, 0.45);
  color: #fff;
  font-size: 22rpx;
  text-align: center;
}

.real-photo-box__camera {
  position: relative;
  width: 72rpx;
  height: 56rpx;
  margin-bottom: 12rpx;
  background: #f4eaec;
  border-radius: 12rpx;
}

.real-photo-box__lens {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 28rpx;
  height: 28rpx;
  margin: -14rpx 0 0 -14rpx;
  border: 4rpx solid #c9a8b0;
  border-radius: 50%;
}

.real-photo-box__title {
  font-size: 26rpx;
  font-weight: 650;
}

.real-photo-box__sub {
  margin-top: 6rpx;
  color: var(--muted);
  font-size: 20rpx;
}

.picked-hint {
  margin-top: 16rpx;
  padding: 12rpx 16rpx;
  background: var(--pink-soft);
  border-radius: 10rpx;
  color: var(--coral);
  font-size: 22rpx;
  text-align: center;
}

/* —— Confirm —— */
.confirm-card {
  padding: 8rpx 20rpx 20rpx;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
  box-shadow: 0 10rpx 26rpx rgba(108, 82, 92, 0.05);
}

.confirm-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 18rpx 0;
}

.confirm-swatch {
  width: 100rpx;
  height: 100rpx;
  flex: none;
  border-radius: 12rpx;
  display: flex;
  align-items: flex-end;
  padding: 10rpx;
}

.confirm-swatch text {
  padding: 2rpx 8rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 6rpx;
  font-family: "Kaiti SC", "STKaiti", serif;
  font-size: 20rpx;
  font-weight: 700;
}

.confirm-photo {
  width: 100rpx;
  height: 100rpx;
  flex: none;
  border-radius: 12rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.confirm-photo__img {
  width: 100%;
  height: 100%;
}

.confirm-photo__emoji {
  font-size: 44rpx;
}

.confirm-copy {
  flex: 1;
  min-width: 0;
}

.confirm-label {
  color: var(--muted);
  font-size: 20rpx;
}

.confirm-value {
  margin-top: 4rpx;
  font-size: 28rpx;
  font-weight: 650;
}

.confirm-sub {
  margin-top: 4rpx;
  color: var(--muted);
  font-size: 20rpx;
}

.confirm-divider {
  height: 2rpx;
  background: var(--line);
}

.confirm-cost {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 18rpx;
}

.confirm-cost__value {
  margin-top: 4rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--coral);
}

.confirm-cost__value text {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--muted);
}

.confirm-cost__tag {
  padding: 8rpx 16rpx;
  background: var(--mint-soft);
  border-radius: 999rpx;
  color: var(--green);
  font-size: 22rpx;
  font-weight: 600;
}

/* —— Actions —— */
.guide-actions {
  margin-top: 28rpx;
  display: flex;
  gap: 16rpx;
}

.guide-actions__half {
  flex: 1;
  min-width: 0;
}

.guide-gen-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.guide-gen-btn__icon {
  width: 32rpx;
  height: 32rpx;
}

/* —— Generating (mirrors job page) —— */
.generating {
  margin-top: 12rpx;
  padding: 64rpx 36rpx 52rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  background: linear-gradient(165deg, #2f433d 0%, #3d5550 48%, #5a6e68 100%);
  border-radius: 20rpx;
  box-shadow: 0 16rpx 40rpx rgba(47, 67, 61, 0.18);
  color: #fff;
}

.progress-flower {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 28rpx;
  animation: flower-spin 4.5s linear infinite;
}

.progress-petal {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 56rpx;
  height: 80rpx;
  margin-left: -28rpx;
  margin-top: -70rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 50%;
  transform-origin: 50% 88%;
}

.progress-petal--1 { transform: rotate(0deg); }
.progress-petal--2 { transform: rotate(90deg); }
.progress-petal--3 { transform: rotate(180deg); }
.progress-petal--4 { transform: rotate(270deg); }

.progress-dot {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 2;
  width: 40rpx;
  height: 40rpx;
  margin-left: -20rpx;
  margin-top: -20rpx;
  background: var(--yellow);
  border: 6rpx solid #fff;
  border-radius: 50%;
  box-sizing: border-box;
}

.generating-title {
  font-family: "Kaiti SC", "STKaiti", "Songti SC", serif;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.3;
}

.generating-status {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
}

.generating-tip {
  margin-top: 22rpx;
  min-height: 72rpx;
  padding: 0 12rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 26rpx;
  line-height: 1.55;
}

.progress-track {
  width: 78%;
  height: 10rpx;
  margin-top: 28rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.22);
  border-radius: 999rpx;
}

.progress-track__bar {
  height: 100%;
  background: linear-gradient(90deg, #ffd978, #fff);
  border-radius: 999rpx;
  transition: width 0.35s ease;
}

.generating-note {
  margin-top: 28rpx;
  max-width: 520rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: 20rpx;
  line-height: 1.6;
}

@keyframes flower-spin {
  to { transform: rotate(360deg); }
}

/* —— Result —— */
.result-compare {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.result-col {
  flex: 1;
  min-width: 0;
}

.result-col__label {
  margin-bottom: 10rpx;
  text-align: center;
  color: var(--muted);
  font-size: 22rpx;
  font-weight: 600;
}

.result-arrow {
  flex: none;
  margin-top: 28rpx;
  color: var(--coral);
  font-size: 32rpx;
  font-weight: 700;
}

.result-frame {
  position: relative;
  height: 320rpx;
  border-radius: 16rpx;
  overflow: hidden;
  border: 2rpx solid var(--line);
  box-shadow: 0 12rpx 28rpx rgba(108, 82, 92, 0.08);
}

.result-frame__img {
  width: 100%;
  height: 100%;
}

.result-frame__img--styled {
  filter: saturate(1.25) contrast(1.05) brightness(1.02);
  transform: scale(1.04);
}

.result-frame__demo {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.result-frame__emoji {
  font-size: 64rpx;
}

.result-frame__name {
  padding: 6rpx 14rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 650;
  color: #5b4d53;
}

.result-frame__overlay {
  position: absolute;
  left: 12rpx;
  bottom: 12rpx;
  padding: 6rpx 14rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 8rpx;
  font-family: "Kaiti SC", "STKaiti", serif;
  font-size: 22rpx;
  font-weight: 700;
  color: #5b4d53;
}

.result-frame__tag {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 4rpx 12rpx;
  background: rgba(48, 40, 44, 0.55);
  color: #fff;
  border-radius: 999rpx;
  font-size: 18rpx;
}

.result-checklist {
  margin-bottom: 24rpx;
  padding: 20rpx 22rpx;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.result-check {
  color: var(--green);
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
}

<view class="page guide-page page-enter" style="padding-top: {{navSpacer}}rpx">
  <custom-nav show-back title="游客模拟生图" show-credit="{{false}}"></custom-nav>

  <view class="guide-loading">
    <view class="guide-flower">
      <view class="guide-petal guide-petal--1"></view>
      <view class="guide-petal guide-petal--2"></view>
      <view class="guide-petal guide-petal--3"></view>
      <view class="guide-petal guide-petal--4"></view>
      <view class="guide-dot"></view>
    </view>
    <view class="guide-title">{{error ? '暂时无法开始模拟' : '正在准备示例照片与推荐风格'}}</view>
    <view class="guide-desc">{{error || '即将进入真实模板、选图、生成进度与结果页面，全程不登录、不上传、不扣积分。'}}</view>
    <button wx:if="{{error}}" class="primary-button guide-button" bindtap="startDemoTour">重新尝试</button>
    <button wx:if="{{error}}" class="ghost-button guide-button" bindtap="goHome">返回首页</button>
  </view>
</view>

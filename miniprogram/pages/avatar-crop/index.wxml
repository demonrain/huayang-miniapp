<view class="page crop-page" style="padding-top: {{navSpacer}}rpx">
  <custom-nav show-back title="制作头像"></custom-nav>

  <view class="crop-tip">双指缩放 · 单指拖动 · 裁切框始终在图片内</view>

  <view
    class="crop-stage"
    style="width: {{stageW}}px; height: {{stageH}}px;"
    catchtouchstart="onTouchStart"
    catchtouchmove="onTouchMove"
    catchtouchend="onTouchEnd"
    catchtouchcancel="onTouchEnd"
  >
    <!-- Image layer: base size covers crop; CSS scale-from-center + translate -->
    <view
      wx:if="{{ready}}"
      class="crop-image-wrap"
      style="width: {{viewW}}px; height: {{viewH}}px; left: {{baseLeft}}px; top: {{baseTop}}px; transform: translate3d({{tx}}px, {{ty}}px, 0) scale({{scale}});"
    >
      <image
        class="crop-image"
        src="{{filePath}}"
        mode="scaleToFill"
        style="width: {{viewW}}px; height: {{viewH}}px;"
      ></image>
    </view>

    <!-- Dark mask with centered crop cutout (pointer-events none so touches hit stage) -->
    <view class="crop-mask">
      <view class="crop-mask__shade crop-mask__top" style="height: {{maskTop}}px"></view>
      <view class="crop-mask__mid" style="height: {{cropPx}}px">
        <view class="crop-mask__shade crop-mask__side" style="width: {{maskSide}}px"></view>
        <view class="crop-frame {{shape === 'circle' ? 'is-circle' : ''}}" style="width: {{cropPx}}px; height: {{cropPx}}px;"></view>
        <view class="crop-mask__shade crop-mask__side" style="width: {{maskSide}}px"></view>
      </view>
      <view class="crop-mask__shade crop-mask__bottom"></view>
    </view>
  </view>

  <view class="crop-toolbar">
    <view class="crop-shapes">
      <view class="crop-shape {{shape === 'square' ? 'is-active' : ''}}" data-shape="square" bindtap="setShape">方形</view>
      <view class="crop-shape {{shape === 'circle' ? 'is-active' : ''}}" data-shape="circle" bindtap="setShape">圆形</view>
    </view>
    <view class="crop-actions">
      <button class="ghost-button crop-btn" bindtap="goBack">取消</button>
      <button class="primary-button crop-btn" loading="{{saving}}" disabled="{{saving || !ready}}" bindtap="saveAvatar">保存到相册</button>
    </view>
  </view>

  <canvas type="2d" id="exportCanvas" class="export-canvas"></canvas>
  <canvas canvas-id="exportCanvasLegacy" class="export-canvas" style="width: {{exportSize}}px; height: {{exportSize}}px;"></canvas>
</view>

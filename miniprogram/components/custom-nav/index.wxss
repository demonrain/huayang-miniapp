.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10000;
  pointer-events: none;
  background: #fff9f8;
  border-bottom: 1rpx solid rgba(240, 227, 229, 0.9);
  box-shadow: 0 6rpx 20rpx rgba(116, 83, 96, 0.04);
  /* Keep solid so page content never shows through while scrolling */
  backdrop-filter: none;
}

.custom-nav__row {
  position: absolute;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding-left: 24rpx;
  box-sizing: border-box;
  pointer-events: auto;
}

.nav-left {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 4rpx;
  overflow: hidden;
}

.nav-back {
  width: 48rpx;
  height: 100%;
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--ink);
  font-size: 44rpx;
  font-weight: 300;
  line-height: 1;
}

.brand-wrap {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 10rpx;
  overflow: hidden;
}

.brand-flower {
  position: relative;
  width: 34rpx;
  height: 34rpx;
  flex: none;
  transform: rotate(-8deg);
}

.petal {
  position: absolute;
  width: 15rpx;
  height: 15rpx;
  background: var(--pink);
  border-radius: 50% 50% 45% 50%;
}

.petal--one { top: 0; left: 9rpx; }
.petal--two { top: 9rpx; right: 0; transform: rotate(90deg); }
.petal--three { bottom: 0; left: 9rpx; transform: rotate(180deg); }
.petal--four { top: 9rpx; left: 0; transform: rotate(270deg); }

.flower-dot {
  position: absolute;
  top: 11rpx;
  left: 11rpx;
  z-index: 2;
  width: 12rpx;
  height: 12rpx;
  background: var(--yellow);
  border: 2rpx solid #fff;
  border-radius: 50%;
  box-sizing: border-box;
}

.brand {
  min-width: 0;
  overflow: hidden;
  font-family: "STXingkai", "Kaiti SC", "Songti SC", serif;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.credit-pill {
  flex: none;
  height: 56rpx;
  min-height: 56rpx;
  max-height: 100%;
  width: auto;
  min-width: 0;
  margin: 0 4rpx 0 0;
  padding: 0 14rpx 0 8rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #fffdfb 0%, #fff5f7 100%);
  border: 2rpx solid #f0dfe4;
  box-shadow: 0 4rpx 12rpx rgba(123, 94, 105, 0.08);
  color: var(--ink);
  font-size: 22rpx;
  font-weight: 650;
  line-height: 1;
  border-radius: 999rpx;
  box-sizing: border-box;
}

.credit-mark {
  width: 32rpx;
  height: 32rpx;
  flex: none;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #ffe9a8, #ffd978);
  color: #8a6b2e;
  font-size: 16rpx;
  font-weight: 700;
  line-height: 32rpx;
  text-align: center;
  box-shadow: inset 0 -2rpx 0 rgba(180, 140, 50, 0.15);
}

.credit-value {
  flex: none;
  min-width: 1.2em;
  overflow: hidden;
  color: #5c4f55;
  font-family: Georgia, "PingFang SC", serif;
  font-size: 24rpx;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
  text-align: left;
  text-overflow: ellipsis;
  white-space: nowrap;
}

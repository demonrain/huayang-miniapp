page {
  --ink: #403b43;
  --muted: #8d858d;
  --paper: #fff9f8;
  --surface: #ffffff;
  --line: #f0e3e5;
  --green: #58ad99;
  --mint: #78c9b5;
  --mint-soft: #e9f7f2;
  --coral: #e76d82;
  --pink: #f28fa0;
  --pink-soft: #fff0f3;
  --peach: #ffb59c;
  --yellow: #ffd978;
  --lavender: #b9a9dc;
  background: linear-gradient(180deg, #fff9f8 0%, #f9fffd 52%, #fffafb 100%);
  color: var(--ink);
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
}

view, text, image, button, input, scroll-view {
  box-sizing: border-box;
}

button {
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  max-width: 100%;
  padding: 16rpx 24rpx 28rpx;
  box-sizing: border-box;
  overflow-x: hidden;
}

/* Content under fixed custom nav: set padding-top via navSpacer inline style */
.page.page-enter {
  position: relative;
}

.section-title {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin: 20rpx 0 12rpx;
}

.section-title__main {
  font-size: 32rpx;
  font-weight: 650;
  letter-spacing: 0;
}

.section-title__sub {
  color: var(--muted);
  font-size: 20rpx;
}

.primary-button {
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--coral);
  color: #fff;
  box-shadow: 0 12rpx 28rpx rgba(231, 109, 130, 0.2);
}

.ghost-button {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border: 2rpx solid var(--line);
  color: var(--ink);
}

.empty {
  padding: 120rpx 32rpx;
  text-align: center;
  color: var(--muted);
}

.skeleton {
  background: #f4eaec;
  animation: pulse 1.2s ease-in-out infinite alternate;
}

.soft-card {
  background: var(--surface);
  border: 2rpx solid rgba(240, 227, 229, 0.9);
  border-radius: 16rpx;
  box-shadow: 0 12rpx 32rpx rgba(107, 80, 90, 0.06);
}

/* Only opacity — transform on ancestors breaks position:fixed nav on WeChat */
.page-enter {
  animation: page-in 0.35s ease-out both;
}

@keyframes pulse {
  from { opacity: 0.55; }
  to { opacity: 1; }
}

@keyframes page-in {
  from { opacity: 0; }
  to { opacity: 1; }
}
